<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mã QR nhận race-kit<% if (typeof event !== 'undefined' && event && event.name) { %> · <%= event.name %><% } %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
    <style>body { font-family: Inter, system-ui, sans-serif; }</style>
</head>
<body class="min-h-screen bg-gradient-to-b from-slate-50 to-slate-100 text-slate-800">
    <main class="mx-auto max-w-md px-4 py-10">
        <div class="rounded-2xl bg-white p-6 shadow-lg ring-1 ring-slate-200/80">
            <h1 class="text-center text-lg font-bold text-slate-900 leading-snug">
                <% if (typeof event !== 'undefined' && event && event.name) { %><%= event.name %><% } else { %>Sự kiện<% } %>
            </h1>
            <p class="mt-3 text-center text-sm text-slate-600 leading-relaxed">
                Vui lòng dùng mã QR này để nhận race-kit.<br />
                <span class="text-slate-500">Please use this QR code to collect your race-kit.</span>
            </p>
            <% var pn = participant && participant.fullname ? String(participant.fullname) : ''; %>
            <% var bib = participant && participant.bib != null ? String(participant.bib) : ''; %>
            <% if (pn || bib) { %>
            <div class="mt-4 rounded-xl bg-slate-50 px-4 py-3 text-center text-sm">
                <% if (pn) { %><p class="font-semibold text-slate-800"><%= pn %></p><% } %>
                <% if (bib) { %><p class="mt-1 text-slate-600">BIB <span class="font-bold text-amber-700"><%= bib %></span></p><% } %>
            </div>
            <% } %>
            <div class="mt-6 flex justify-center">
                <% if (qrDataUrl) { %>
                <img src="<%= qrDataUrl %>" alt="QR Code" width="280" height="280" class="rounded-xl border-4 border-white shadow-md ring-2 ring-slate-200" />
                <% } else { %>
                <p class="text-sm text-red-600">Không tạo được mã QR. Kiểm tra cấu hình PUBLIC_BASE_URL trên hệ thống.</p>
                <% } %>
            </div>
            <p class="mt-6 text-center text-xs leading-relaxed text-slate-500">
                Mã QR trùng với nội dung đã gửi trong email của bạn.
            </p>
        </div>
    </main>
</body>
</html>
