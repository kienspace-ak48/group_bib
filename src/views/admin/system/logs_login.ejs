<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
  <div>
    <h4 class="mb-1">Lịch sử đăng nhập</h4>
    <p class="text-body-secondary small mb-0">Ghi nhận khi đăng nhập admin (mật khẩu).</p>
  </div>
  <a href="/admin/system/logs/audit" class="btn btn-outline-secondary btn-sm">Nhật ký thao tác</a>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0 small">
        <thead class="table-light">
          <tr>
            <th>Thời điểm</th>
            <th>Account</th>
            <th>OK</th>
            <th>Lý do lỗi</th>
            <th>IP</th>
            <th>User-Agent</th>
          </tr>
        </thead>
        <tbody>
          <% if (!items || !items.length) { %>
          <tr>
            <td colspan="6" class="text-center text-body-secondary py-5">Chưa có bản ghi.</td>
          </tr>
          <% } else { %>
          <% items.forEach(function (row) { %>
          <tr>
            <td><%= row.at ? formatDateTimeVn(row.at) : '—' %></td>
            <td><%= row.account_display != null && row.account_display !== '' ? row.account_display : '—' %></td>
            <td><%= row.success ? '✓' : '✗' %></td>
            <td><%= row.failure_reason || '—' %></td>
            <td class="text-break" style="max-width:120px;"><%= row.ip || '—' %></td>
            <td class="text-break text-body-secondary" style="max-width:200px;"><%= (row.user_agent || '').slice(0, 120) %></td>
          </tr>
          <% }); %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  <% if (pages > 1) { %>
  <div class="card-footer d-flex justify-content-between align-items-center">
    <span class="small text-body-secondary">Trang <%= page %> / <%= pages %> (<%= total %> bản ghi)</span>
    <nav>
      <ul class="pagination pagination-sm mb-0">
        <% if (page > 1) { %>
        <li class="page-item"><a class="page-link" href="?page=<%= page - 1 %>">Trước</a></li>
        <% } %>
        <% if (page < pages) { %>
        <li class="page-item"><a class="page-link" href="?page=<%= page + 1 %>">Sau</a></li>
        <% } %>
      </ul>
    </nav>
  </div>
  <% } %>
</div>
