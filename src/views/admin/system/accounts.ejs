<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
  <div>
    <h4 class="mb-1">Tài khoản hệ thống</h4>
    <p class="text-body-secondary small mb-0">
      <% if (typeof canManageFullAccounts !== 'undefined' && canManageFullAccounts) { %>
      <code>super_admin</code>: tạo / sửa / xóa mọi vai trò. Admin có quyền <code>admin.system.accounts</code> (không phải super): chỉ xem danh sách tài khoản <code>account_checkin</code> và chỉnh sự kiện check-in / trạng thái / mật khẩu — không thấy tài khoản admin khác.
      <% } else { %>
      Bạn chỉ xem và chỉnh tài khoản <code>account_checkin</code> (không xem tài khoản admin/super khác trong hệ thống).
      <% } %>
    </p>
  </div>
  <% if (typeof canManageFullAccounts !== 'undefined' && canManageFullAccounts) { %>
  <a href="/admin/system/accounts/new" class="btn btn-primary">Tạo tài khoản</a>
  <% } %>
</div>

<% if (flash && flash.message) { %>
<div class="alert alert-<%= flash.type === 'success' ? 'success' : flash.type === 'warning' ? 'warning' : 'danger' %> alert-dismissible fade show" role="alert">
  <%= flash.message %>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<% } %>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Tên</th>
            <th>Email</th>
            <% if (typeof canManageFullAccounts !== 'undefined' && canManageFullAccounts) { %>
            <th>Vai trò</th>
            <th>Quyền</th>
            <% } else { %>
            <th>Sự kiện check-in</th>
            <% } %>
            <th>Trạng thái</th>
            <th class="text-end">Thao tác</th>
          </tr>
        </thead>
        <tbody>
          <% if (!accounts || !accounts.length) { %>
          <tr>
            <td colspan="<%= (typeof canManageFullAccounts !== 'undefined' && canManageFullAccounts) ? 6 : 5 %>" class="text-center text-body-secondary py-5">Chưa có tài khoản.</td>
          </tr>
          <% } else { %>
          <% accounts.forEach(function (a) { %>
          <tr>
            <td class="fw-semibold"><%= a.name || '—' %></td>
            <td><code class="small"><%= a.email || '—' %></code></td>
            <% if (typeof canManageFullAccounts !== 'undefined' && canManageFullAccounts) { %>
            <td><span class="badge text-bg-secondary"><%= a.role || '—' %></span></td>
            <td class="small text-body-secondary" style="max-width: 220px;">
              <%= (a.permissions && a.permissions.length) ? a.permissions.join(', ') : '—' %>
            </td>
            <% } else { %>
            <td class="small">
              <% if (a.checkin_event_id && a.checkin_event_id.name) { %>
              <%= a.checkin_event_id.name %><% if (a.checkin_event_id.start_date) { %> · <%= new Date(a.checkin_event_id.start_date).toLocaleDateString('vi-VN') %><% } %>
              <% } else { %>
              <span class="text-body-secondary">—</span>
              <% } %>
            </td>
            <% } %>
            <td>
              <% if (a.status) { %>
              <span class="badge text-bg-success">Bật</span>
              <% } else { %>
              <span class="badge text-bg-secondary">Tắt</span>
              <% } %>
            </td>
            <td class="text-end">
              <% var canEditRow = (typeof canManageFullAccounts !== 'undefined' && canManageFullAccounts) || (a.role === 'account_checkin'); %>
              <% if (canEditRow) { %>
              <a href="/admin/system/accounts/<%= a._id %>/edit" class="btn btn-sm btn-outline-primary">Sửa</a>
              <% } else { %>
              <span class="small text-body-secondary">—</span>
              <% } %>
              <% if (typeof canManageFullAccounts !== 'undefined' && canManageFullAccounts && typeof user !== 'undefined' && user && String(user._id) !== String(a._id)) { %>
              <form method="POST" action="/admin/system/accounts/<%= a._id %>/delete" class="d-inline" onsubmit="return confirm('Xóa tài khoản này?');">
                <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
              </form>
              <% } %>
            </td>
          </tr>
          <% }); %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  <% if (pages > 1) { %>
  <div class="card-footer d-flex justify-content-between align-items-center">
    <span class="small text-body-secondary">Trang <%= page %> / <%= pages %> (<%= total %> tài khoản)</span>
    <nav>
      <ul class="pagination pagination-sm mb-0">
        <% if (page > 1) { %>
        <li class="page-item"><a class="page-link" href="?page=<%= page - 1 %>">Trước</a></li>
        <% } %>
        <% if (page < pages) { %>
        <li class="page-item"><a class="page-link" href="?page=<%= page + 1 %>">Sau</a></li>
        <% } %>
      </ul>
    </nav>
  </div>
  <% } %>
</div>
