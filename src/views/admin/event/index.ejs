<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
  <div>
    <h4 class="mb-1">Sự kiện check-in</h4>
    <p class="text-body-secondary small mb-0">Quản lý theo model <code>event_checkin_h</code>. Mở từng sự kiện để xem tiến trình &amp; dữ liệu từng bước.</p>
  </div>
</div>

<% if (flash && flash.message) { %>
<div class="alert alert-<%= flash.type === 'success' ? 'success' : flash.type === 'warning' ? 'warning' : 'danger' %> alert-dismissible fade show" role="alert">
  <%= flash.message %>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<% } %>

<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-body-tertiary"><strong>Tạo sự kiện mới</strong></div>
  <div class="card-body">
    <form method="POST" action="/admin/event" class="row g-2 align-items-end">
      <div class="col-md-8">
        <label class="form-label small">Tên sự kiện <span class="text-danger">*</span></label>
        <input type="text" name="name" class="form-control" required placeholder="Ví dụ: Giải chạy ABC 2026" maxlength="200" />
      </div>
      <div class="col-md-4">
        <button type="submit" class="btn btn-primary w-100">Tạo &amp; mở workspace</button>
      </div>
    </form>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Tên</th>
            <th>Slug</th>
            <th class="text-center">Giai đoạn (0–4)</th>
            <th>Cập nhật</th>
            <th class="text-end">Thao tác</th>
          </tr>
        </thead>
        <tbody>
          <% if (!events || !events.length) { %>
          <tr>
            <td colspan="5" class="text-center text-body-secondary py-5">Chưa có sự kiện nào.</td>
          </tr>
          <% } else { %>
          <% events.forEach(function (ev) { %>
          <tr>
            <td class="fw-semibold"><%= ev.name || '—' %></td>
            <td><code class="small"><%= ev.slug || '—' %></code></td>
            <td class="text-center">
              <span class="badge text-bg-secondary"><%= ev.workflow_step != null ? ev.workflow_step : 0 %></span>
            </td>
            <td class="small text-body-secondary">
              <%= ev.updatedAt ? new Date(ev.updatedAt).toLocaleString('vi-VN') : '—' %>
            </td>
            <td class="text-end">
              <div class="d-inline-flex flex-wrap gap-1 justify-content-end">
                <% var _ws = ev.workflow_step != null ? Math.min(4, Math.max(0, Number(ev.workflow_step))) : 0; %>
                <a href="/admin/event/<%= ev._id %>/step/<%= _ws %>" class="btn btn-sm btn-primary">Mở workspace</a>
                <form method="POST" action="/admin/event/<%= ev._id %>/delete" class="d-inline" onsubmit="return confirm('Xóa vĩnh viễn sự kiện này và toàn bộ VĐV?');">
                  <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                </form>
              </div>
            </td>
          </tr>
          <% }); %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
