<% 
  var publicBaseUrlHint = typeof publicBaseUrlHint !== 'undefined' ? publicBaseUrlHint : '';
  var ev = typeof event !== 'undefined' ? event : {};
  var mc = typeof mailConfig !== 'undefined' && mailConfig ? mailConfig : {};
  var mailN = typeof mailEligibleCount !== 'undefined' ? mailEligibleCount : 0;
  var mailWaiverN = typeof mailWaiverPendingCount !== 'undefined' ? mailWaiverPendingCount : 0;
  var owFlow = ev.online_waiver_first_flow === true;
  var sgOk = typeof sendgridConfigured !== 'undefined' ? sendgridConfigured : false;
  var eventId = ev._id ? String(ev._id) : '';
  var hasMailTitle = mc.title && String(mc.title).trim();
  var mjb = typeof mailBulkJobLatest !== 'undefined' && mailBulkJobLatest ? mailBulkJobLatest : null;
  var showBulkProgress = mjb && (mjb.status === 'queued' || mjb.status === 'running');
%>
<div class="card border-0 shadow-sm mb-4 <%= ws === 2 ? 'border-primary border-2' : '' %>">
  <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
    <div>
      <strong>3. Mail QR code</strong>
      <% if (ws === 2) { %><span class="badge bg-primary ms-2">Đang làm</span><% } %>
    </div>
  </div>
  <div class="card-body border-bottom">
    <p class="small text-body-secondary mb-2">
      Cấu hình nội dung email và gửi hàng loạt qua <strong>SendGrid</strong>.
      <% if (owFlow) { %>
      <strong>Luồng miễn trừ online:</strong> dùng nút <em>Gửi mail mời ký miễn trừ</em> trước (không QR). Sau khi VĐV ký trên web, hệ thống gửi mail có QR. Hoặc dùng <em>Gửi mail hàng loạt</em> để gửi QR cho người đã ký / không bật luồng chờ ký.
      <% } else { %>
      Mỗi người nhận một email có QR (nội dung mã = token quét). Chỉ gửi tới bản ghi có <strong>email hợp lệ</strong>.
      <% } %>
    </p>
    <ul class="small mb-0">
      <li>Người đủ điều kiện nhận mail QR (ước lượng): <strong><%= mailN %></strong></li>
      <% if (owFlow) { %>
      <li>Chưa ký miễn trừ online — đủ điều kiện nhận mail <strong>mời ký</strong>: <strong><%= mailWaiverN %></strong></li>
      <% } %>
      <li>SendGrid: <% if (sgOk) { %><span class="text-success">Đã cấu hình (API key + From)</span><% } else { %><span class="text-danger">Thiếu env: API key <code>SENDGRID_API_KEY</code> hoặc <code>SENDGRID_API_KEY_DOMAIN</code>, và From <code>SENDGRID_FROM_EMAIL</code> / <code>SENDGRID_FROM_DOMAIN</code> / <code>SENDGRID_FROM</code></span><% } %></li>
    </ul>
  </div>

  <div class="card-body border-bottom bg-body-tertiary bg-opacity-25">
    <div class="d-flex flex-wrap gap-2 align-items-center">
      <button
        type="button"
        class="btn btn-outline-secondary btn-sm"
        id="btn_mail_preview"
        <%= !hasMailTitle ? 'disabled title="Lưu cấu hình mail (có tiêu đề) trước — preview dùng dữ liệu đã lưu trên server."' : '' %>
      >
        Xem preview email
      </button>
      <button type="button" class="btn btn-success btn-sm" id="btn_send_bulk_mail" <%= !sgOk || !mailN ? 'disabled' : '' %>>
        Gửi mail hàng loạt (QR)
      </button>
      <% if (owFlow) { %>
      <button type="button" class="btn btn-outline-success btn-sm" id="btn_send_waiver_bulk_mail" <%= !sgOk || !mailWaiverN ? 'disabled' : '' %>>
        Gửi mail mời ký miễn trừ (không QR)
      </button>
      <% } %>
      <span class="small text-body-secondary d-block" id="send_bulk_status"></span>
      <div id="bulk_mail_progress_wrap" class="w-100 mt-3 <%= showBulkProgress ? '' : 'd-none' %>">
        <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
          <span id="bulk_mail_badge" class="badge bg-primary">Đang gửi…</span>
          <span id="bulk_mail_spinner" class="spinner-border spinner-border-sm text-primary <%= showBulkProgress ? '' : 'd-none' %>" role="status" aria-hidden="true"></span>
          <span id="bulk_mail_updated" class="small text-body-secondary"></span>
        </div>
        <div class="progress mb-2" style="height: 1.35rem" id="bulk_mail_progress_container">
          <div
            id="bulk_mail_progress_bar"
            class="progress-bar"
            role="progressbar"
            style="width: 0%"
            aria-valuenow="0"
            aria-valuemin="0"
            aria-valuemax="100"
          >0%</div>
        </div>
        <div class="small text-body-secondary mb-1" id="bulk_mail_counts"></div>
        <pre class="small text-danger mb-0 d-none text-wrap" id="bulk_mail_err_sample" style="white-space: pre-wrap; max-height: 8rem; overflow: auto;"></pre>
      </div>
      <pre class="small text-danger mt-2 mb-0 d-none text-wrap" id="send_bulk_errors" style="white-space: pre-wrap; max-height: 12rem; overflow: auto;"></pre>
    </div>
    <% if (!mailN) { %>
    <p class="small text-warning mb-0 mt-2">Không có email hợp lệ cho mail QR — kiểm tra bước 2 (cột email).</p>
    <% } %>
    <% if (owFlow && !mailWaiverN) { %>
    <p class="small text-body-secondary mb-0 mt-2">Không còn VĐV cần mail mời ký (đã ký hết hoặc thiếu email).</p>
    <% } %>
  </div>

  <div class="card-header"><strong>Cấu hình nội dung email</strong></div>
  <div class="card-body">
    <p class="small text-body-secondary mb-3">
      Thứ tự bên dưới trùng với email nhận được: <strong>trên → dưới</strong> (banner → nội dung → chân email).
    </p>

    <div class="row g-2 mb-3">
      <div class="col-md-6">
        <label class="form-label small mb-0 text-body-secondary" for="sender_name">From (tên hiển thị)</label>
        <input type="text" id="sender_name" class="form-control form-control-sm" value="<%= mc.sender_name || '' %>" maxlength="120" />
      </div>
      <div class="col-md-6">
        <label class="form-label small mb-0 text-body-secondary" for="mail_title">Tiêu đề (subject)</label>
        <input type="text" id="mail_title" class="form-control form-control-sm" value="<%= mc.title || '' %>" maxlength="200" />
      </div>
    </div>

    <div class="border rounded p-3 mb-3">
      <div class="fw-semibold small mb-2 text-body-secondary">2. Banner đầu email</div>
      <div class="row g-3">
        <div class="col-lg-6">
          <div class="form-check mb-2">
            <input type="checkbox" class="form-check-input" id="banner_option" <%= mc.banner_option ? 'checked' : '' %> />
            <label class="form-check-label" for="banner_option">Bật = dùng ảnh banner (tắt = dùng dòng chữ bên dưới)</label>
          </div>
          <label class="form-label small">Dòng chữ khi không dùng ảnh</label>
          <input type="text" class="form-control form-control-sm" id="banner_text" value="<%= mc.banner_text || '' %>" />
          <div class="mt-3">
            <label class="form-label small">Ảnh banner hiện tại</label>
            <input type="text" class="form-control form-control-sm mb-2" id="banner_img_hidden" value="<%= mc.banner_img || '' %>" readonly />
            <input type="file" accept="image/*" class="form-control form-control-sm" id="banner_file" />
            <button type="button" class="btn btn-outline-info btn-sm mt-2" id="btn_banner_upload">Upload banner</button>
            <span class="small ms-2" id="banner_upload_status"></span>
          </div>
        </div>
        <div class="col-lg-6">
          <% if (mc.banner_img) { %>
          <div class="border rounded p-2 bg-body-tertiary">
            <img id="previewImg" src="<%= mc.banner_img %>" alt="Banner" class="img-fluid" style="max-height: 200px; object-fit: contain;" />
          </div>
          <% } else { %>
          <p class="small text-body-secondary mb-0">Chưa có ảnh banner.</p>
          <% } %>
        </div>
      </div>
    </div>

    <div class="border rounded p-3 mb-3">
      <div class="fw-semibold small mb-2 text-body-secondary">3. Nội dung 1</div>
      <textarea id="event-mail-content-1" class="form-control form-control-sm"><%- mc.content_1 || '' %></textarea>
    </div>

    <div class="border rounded p-3 mb-3 bg-body-tertiary bg-opacity-25">
      <div class="fw-semibold small mb-1 text-body-secondary">3b. Nội dung 1 — mail ủy quyền</div>
      <p class="small text-body-secondary mb-2 mb-md-1">
        Dùng thay khối &quot;Nội dung 1&quot; khi gửi cho <strong>người được ủy quyền</strong> hoặc mail nhóm (đại diện). Để trống = dùng nội dung 1 chung.
      </p>
      <textarea id="event-mail-delegation-content-1" class="form-control form-control-sm"><%- mc.delegation_content_1 || '' %></textarea>
    </div>

    <div class="border rounded p-3 mb-3">
      <div class="fw-semibold small mb-2 text-body-secondary">4. Nội dung 2</div>
      <p class="small text-body-secondary mb-2">Hiển thị sau bảng thông tin VĐV (trước chân email).</p>
      <textarea id="event-mail-content-2" class="form-control form-control-sm"><%- mc.content_2 || '' %></textarea>
    </div>

    <div class="border rounded p-3 mb-3">
      <div class="fw-semibold small mb-2 text-body-secondary">5. Chân email (footer)</div>
      <p class="small text-body-secondary mb-2">
        Soạn giống nội dung 1–2 (in đậm, danh sách, liên kết). <strong>Màu nền / màu chữ</strong> hai ô bên dưới áp cho
        <em>toàn bộ ô chân email</em> (phần có nội dung bạn soạn). Nếu muốn nền xanh đậm cho đoạn giới thiệu,
        đặt màu ở đây — tránh thêm trong editor một khối div nền màu ở cuối không có chữ (sẽ thành vạch trống dưới mail).
      </p>
      <textarea id="footer_body" class="form-control form-control-sm"><%- mc.footer_body || '' %></textarea>
      <div class="row g-2 mt-2">
        <div class="col-sm-6">
          <label class="form-label small mb-0">Màu nền footer</label>
          <div class="d-flex gap-1">
            <input type="color" class="form-control form-control-color" id="footer_bg_color" value="<%= mc.footer_bg_color || '#f8f8f8' %>" />
            <input type="text" class="form-control form-control-sm" id="footer_bg_color_text" value="<%= mc.footer_bg_color || '#f8f8f8' %>" />
          </div>
        </div>
        <div class="col-sm-6">
          <label class="form-label small mb-0">Màu chữ footer</label>
          <div class="d-flex gap-1">
            <input type="color" class="form-control form-control-color" id="footer_text_color" value="<%= mc.footer_text_color || '#666666' %>" />
            <input type="text" class="form-control form-control-sm" id="footer_text_color_text" value="<%= mc.footer_text_color || '#666666' %>" />
          </div>
        </div>
      </div>
    </div>

    <button type="button" class="btn btn-primary btn-sm" id="btn_mail_config_save">Lưu cấu hình</button>
    <span class="small ms-2 text-body-secondary" id="mail_config_save_status"></span>
  </div>
</div>

<div class="card border-0 shadow-sm mb-4" id="mail_delivery_logs_card">
  <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
    <strong>Nhật ký phân phối (SendGrid)</strong>
    <button type="button" class="btn btn-outline-secondary btn-sm" id="btn_mail_logs_refresh">Làm mới</button>
  </div>
  <div class="card-body">
    <p class="small text-body-secondary mb-2">
      Hiển thị sự kiện từ <strong>SendGrid Event Webhook</strong> (delivered, bounce, …). Cấu hình URL POST:
      <code class="user-select-all">/webhooks/sendgrid</code>
      <% if (typeof publicBaseUrlHint !== 'undefined' && publicBaseUrlHint) { %>
      — ví dụ: <code class="user-select-all text-break"><%= publicBaseUrlHint %>/webhooks/sendgrid?key=…</code>
      <% } %>
      và biến môi trường <code>SENDGRID_WEBHOOK_SECRET</code> (cùng giá trị với <code>?key=</code>).
    </p>
    <div class="table-responsive">
      <table class="table table-sm table-striped align-middle mb-0" id="mail_delivery_logs_table">
        <thead>
          <tr>
            <th>Thời gian</th>
            <th>Người nhận</th>
            <th>Loại mail</th>
            <th>Trạng thái SG</th>
            <th>Ghi chú</th>
          </tr>
        </thead>
        <tbody id="mail_delivery_logs_tbody">
          <tr><td colspan="5" class="text-body-secondary small">Đang tải…</td></tr>
        </tbody>
      </table>
    </div>
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mt-2">
      <span class="small text-body-secondary" id="mail_delivery_logs_meta"></span>
      <div class="btn-group btn-group-sm">
        <button type="button" class="btn btn-outline-secondary" id="mail_delivery_logs_prev" disabled>Trước</button>
        <button type="button" class="btn btn-outline-secondary" id="mail_delivery_logs_next" disabled>Sau</button>
      </div>
    </div>
  </div>
</div>

<script src="/admin/assets/js/plugins/tinymce/tinymce.min.js"></script>
<script>
(function () {
  var eventId = '<%= eventId %>';
  if (!eventId) return;

  var initialJob = <%- JSON.stringify(mjb) %>;
  var bulkPollTimer = null;

  function fmtTime(d) {
    if (!d) return '';
    try {
      var x = typeof d === 'string' ? new Date(d) : d;
      return x.toLocaleString('vi-VN', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    } catch (e) {
      return '';
    }
  }

  function applyBulkJobUI(job) {
    var wrap = document.getElementById('bulk_mail_progress_wrap');
    var bar = document.getElementById('bulk_mail_progress_bar');
    var counts = document.getElementById('bulk_mail_counts');
    var badge = document.getElementById('bulk_mail_badge');
    var spin = document.getElementById('bulk_mail_spinner');
    var upd = document.getElementById('bulk_mail_updated');
    var errPre = document.getElementById('bulk_mail_err_sample');
    var st = document.getElementById('send_bulk_status');
    if (!wrap || !bar || !counts || !badge) return;

    var total = job.total || 0;
    var sent = job.sent || 0;
    var failed = job.failed || 0;
    var done = sent + failed;
    var pct = total > 0 ? Math.min(100, Math.round((done / total) * 100)) : 0;

    bar.style.width = pct + '%';
    bar.textContent = pct + '%';
    bar.setAttribute('aria-valuenow', String(pct));
    bar.setAttribute('aria-valuemax', '100');

    if (job.status === 'failed' || (failed > 0 && job.status === 'completed')) {
      bar.classList.remove('bg-success');
      bar.classList.add('bg-warning');
    } else {
      bar.classList.remove('bg-warning');
      if (job.status === 'completed' && failed === 0) bar.classList.add('bg-success');
    }

    counts.innerHTML =
      'Đã gửi thành công: <strong>' +
      sent.toLocaleString('vi-VN') +
      '</strong> / ' +
      total.toLocaleString('vi-VN') +
      (failed > 0 ? ' · <span class="text-danger">Lỗi: ' + failed.toLocaleString('vi-VN') + '</span>' : '');

    if (job.status === 'queued' || job.status === 'running') {
      badge.className = 'badge bg-primary';
      var isWaiver = job.job_kind === 'waiver_request';
      badge.textContent =
        job.status === 'queued'
          ? isWaiver
            ? 'Đang chờ (miễn trừ)…'
            : 'Đang chờ…'
          : isWaiver
            ? 'Đang gửi mail miễn trừ…'
            : 'Đang gửi…';
      if (spin) spin.classList.remove('d-none');
    } else if (job.status === 'completed') {
      badge.className = 'badge bg-success';
      badge.textContent = failed > 0 ? 'Hoàn tất (có lỗi)' : 'Hoàn tất';
      if (spin) spin.classList.add('d-none');
    } else if (job.status === 'failed') {
      badge.className = 'badge bg-danger';
      badge.textContent = 'Thất bại';
      if (spin) spin.classList.add('d-none');
    }

    if (upd) upd.textContent = 'Cập nhật: ' + fmtTime(new Date());

    if (errPre && job.errors_sample && job.errors_sample.length) {
      errPre.textContent = job.errors_sample.slice(0, 20).join('\n');
      errPre.classList.remove('d-none');
    } else if (errPre) {
      errPre.classList.add('d-none');
    }

    if (st && job.status === 'completed') {
      st.textContent =
        'Kết thúc job: ' + sent.toLocaleString('vi-VN') + ' / ' + total.toLocaleString('vi-VN') + ' đã gửi.';
      if (failed > 0) st.textContent += ' Lỗi: ' + failed + '.';
    }

    wrap.classList.remove('d-none');
  }

  function stopBulkPoll() {
    if (bulkPollTimer) {
      clearInterval(bulkPollTimer);
      bulkPollTimer = null;
    }
  }

  function startBulkPoll(jobId) {
    stopBulkPoll();
    function tick() {
      fetch('/admin/event/' + eventId + '/mail/bulk-job/' + encodeURIComponent(jobId))
        .then(function (r) {
          return r.json();
        })
        .then(function (data) {
          if (!data.success || !data.job) return;
          applyBulkJobUI(data.job);
          if (data.job.status === 'completed' || data.job.status === 'failed') {
            stopBulkPoll();
            var btn = document.getElementById('btn_send_bulk_mail');
            if (btn) btn.disabled = false;
            var btnW = document.getElementById('btn_send_waiver_bulk_mail');
            if (btnW) btnW.disabled = false;
          }
        })
        .catch(function () {});
    }
    tick();
    bulkPollTimer = setInterval(tick, 3000);
  }

  if (initialJob && (initialJob.status === 'queued' || initialJob.status === 'running')) {
    applyBulkJobUI(initialJob);
    startBulkPoll(initialJob.id);
    var btn0 = document.getElementById('btn_send_bulk_mail');
    if (btn0) btn0.disabled = true;
    var btnW0 = document.getElementById('btn_send_waiver_bulk_mail');
    if (btnW0) btnW0.disabled = true;
  }

  function initMailTinyMCE() {
    if (typeof tinymce === 'undefined') return;
    tinymce.init({
      height: 280,
      selector: '#event-mail-content-1, #event-mail-delegation-content-1, #event-mail-content-2, #footer_body',
      setup: function (editor) {
        editor.on('init', function () {
          var promo = document.querySelector('.tox-promotion');
          if (promo) promo.remove();
        });
      },
      content_style: 'body { font-family: "Inter", sans-serif; font-size: 14px; }',
      menubar: 'file edit view insert format tools table help',
      toolbar: [
        'styleselect fontselect fontsizeselect',
        'undo redo cut copy paste bold italic | bullist numlist | alignleft aligncenter alignright alignjustify',
        'link image',
      ],
      plugins: 'list advlist autolink link image lists charmap print preview code',
    });
    setTimeout(function () {
      document.querySelectorAll('.tox-promotion').forEach(function (el) { el.remove(); });
    }, 0);
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMailTinyMCE);
  } else {
    initMailTinyMCE();
  }

  function editorContent(id) {
    var ed = typeof tinymce !== 'undefined' ? tinymce.get(id) : null;
    if (ed) return ed.getContent();
    var el = document.getElementById(id);
    return el ? el.value : '';
  }

  function setupColorSync(colorId, textId) {
    var c = document.getElementById(colorId);
    var t = document.getElementById(textId);
    if (!c || !t) return;
    c.addEventListener('input', function () { t.value = c.value; });
    t.addEventListener('input', function () {
      if (/^#[0-9A-Fa-f]{6}$/.test(t.value)) c.value = t.value;
    });
  }
  setupColorSync('footer_bg_color', 'footer_bg_color_text');
  setupColorSync('footer_text_color', 'footer_text_color_text');

  function gatherPayload() {
    return {
      sender_name: document.getElementById('sender_name').value,
      title: document.getElementById('mail_title').value,
      content_1: editorContent('event-mail-content-1'),
      delegation_content_1: editorContent('event-mail-delegation-content-1'),
      content_2: editorContent('event-mail-content-2'),
      banner_option: document.getElementById('banner_option').checked,
      banner_text: document.getElementById('banner_text').value,
      banner_img: document.getElementById('banner_img_hidden').value,
      footer_body: editorContent('footer_body'),
      footer_bg_color: document.getElementById('footer_bg_color').value,
      footer_text_color: document.getElementById('footer_text_color').value,
    };
  }

  document.getElementById('btn_mail_config_save').addEventListener('click', function () {
    var st = document.getElementById('mail_config_save_status');
    st.textContent = 'Đang lưu…';
    fetch('/admin/event/' + eventId + '/mail-config', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(gatherPayload()),
    })
      .then(function (r) { return r.json().then(function (j) { return { ok: r.ok, j: j }; }); })
      .then(function (_ref) {
        if (_ref.ok && _ref.j.success) {
          st.textContent = 'Đã lưu.';
          setTimeout(function () { st.textContent = ''; }, 3000);
        } else {
          st.textContent = _ref.j.message || 'Lỗi lưu.';
        }
      })
      .catch(function () { st.textContent = 'Lỗi mạng.'; });
  });

  document.getElementById('btn_banner_upload').addEventListener('click', function () {
    var input = document.getElementById('banner_file');
    var st = document.getElementById('banner_upload_status');
    if (!input.files || !input.files[0]) {
      st.textContent = 'Chọn file ảnh.';
      return;
    }
    var fd = new FormData();
    fd.append('file', input.files[0]);
    st.textContent = 'Đang upload…';
    fetch('/admin/event/' + eventId + '/mail/banner', { method: 'POST', body: fd })
      .then(function (r) { return r.json().then(function (j) { return { ok: r.ok, j: j }; }); })
      .then(function (_ref2) {
        if (_ref2.ok && _ref2.j.success) {
          st.textContent = 'Xong. Tải lại trang…';
          window.location.reload();
        } else {
          st.textContent = _ref2.j.message || 'Lỗi upload.';
        }
      })
      .catch(function () { st.textContent = 'Lỗi mạng.'; });
  });

  var btnPreview = document.getElementById('btn_mail_preview');
  if (btnPreview && !btnPreview.disabled) {
    btnPreview.addEventListener('click', function () {
      window.open('/admin/event/' + eventId + '/mail/preview', '_blank', 'noopener,noreferrer');
    });
  }

  var btnBulk = document.getElementById('btn_send_bulk_mail');
  if (btnBulk) {
    btnBulk.addEventListener('click', function () {
      if (!confirm('Gửi email QR tới tất cả người có email hợp lệ? (Job chạy nền — có thể đóng trang, server vẫn gửi.)')) return;
      var st = document.getElementById('send_bulk_status');
      var errEl = document.getElementById('send_bulk_errors');
      if (errEl) {
        errEl.classList.add('d-none');
        errEl.textContent = '';
      }
      st.textContent = 'Đang tạo job…';
      btnBulk.disabled = true;
      var btnWv = document.getElementById('btn_send_waiver_bulk_mail');
      if (btnWv) btnWv.disabled = true;
      fetch('/admin/event/' + eventId + '/mail/send-bulk', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' })
        .then(function (r) {
          return r.json().then(function (j) {
            return { ok: r.ok, status: r.status, j: j };
          });
        })
        .then(function (ref) {
          var j = ref.j;
          if (ref.ok && j.success && j.jobId) {
            st.textContent = j.message || 'Đã đưa vào hàng đợi.';
            applyBulkJobUI({
              id: j.jobId,
              status: 'queued',
              total: j.totalRecipients || 0,
              sent: 0,
              failed: 0,
              errors_sample: [],
            });
            startBulkPoll(j.jobId);
            return;
          }
          st.textContent = (j && j.message) ? j.message : 'Lỗi.';
          btnBulk.disabled = false;
          if (btnWv) btnWv.disabled = false;
        })
        .catch(function () {
          st.textContent = 'Lỗi mạng.';
          btnBulk.disabled = false;
          if (btnWv) btnWv.disabled = false;
        });
    });
  }

  var btnWaiverBulk = document.getElementById('btn_send_waiver_bulk_mail');
  if (btnWaiverBulk) {
    btnWaiverBulk.addEventListener('click', function () {
      if (!confirm('Gửi email mời ký miễn trừ (không có QR) tới mọi người chưa ký và có email hợp lệ?')) return;
      var st = document.getElementById('send_bulk_status');
      var errEl = document.getElementById('send_bulk_errors');
      if (errEl) {
        errEl.classList.add('d-none');
        errEl.textContent = '';
      }
      st.textContent = 'Đang tạo job…';
      btnWaiverBulk.disabled = true;
      var btnBulkSafe = document.getElementById('btn_send_bulk_mail');
      if (btnBulkSafe) btnBulkSafe.disabled = true;
      fetch('/admin/event/' + eventId + '/mail/send-bulk-waiver', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: '{}',
      })
        .then(function (r) {
          return r.json().then(function (j) {
            return { ok: r.ok, status: r.status, j: j };
          });
        })
        .then(function (ref) {
          var j = ref.j;
          if (ref.ok && j.success && j.jobId) {
            st.textContent = j.message || 'Đã đưa vào hàng đợi.';
            applyBulkJobUI({
              id: j.jobId,
              job_kind: 'waiver_request',
              status: 'queued',
              total: j.totalRecipients || 0,
              sent: 0,
              failed: 0,
              errors_sample: [],
            });
            startBulkPoll(j.jobId);
            return;
          }
          st.textContent = (j && j.message) ? j.message : 'Lỗi.';
          btnWaiverBulk.disabled = false;
          if (btnBulkSafe) btnBulkSafe.disabled = false;
        })
        .catch(function () {
          st.textContent = 'Lỗi mạng.';
          btnWaiverBulk.disabled = false;
          if (btnBulkSafe) btnBulkSafe.disabled = false;
        });
    });
  }

  var mailLogsPage = 1;
  var mailLogsLimit = 25;
  function escHtml(s) {
    if (s == null) return '';
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }
  function mailKindLabel(k) {
    var m = { qr: 'Mail QR', waiver_request: 'Mời ký miễn trừ', group_delegate: 'Nhóm (đại diện)', group_bib: 'Nhóm BIB' };
    return m[k] || k || '—';
  }
  function sgEventLabel(ev) {
    var m = {
      delivered: 'delivered (đã giao tới MX)',
      bounce: 'bounce',
      dropped: 'dropped',
      deferred: 'deferred',
      processed: 'processed',
      open: 'open',
    };
    return m[ev] || ev || '—';
  }
  function fmtTs(d) {
    if (!d) return '—';
    try {
      return new Date(d).toLocaleString('vi-VN');
    } catch (e) {
      return '—';
    }
  }
  function loadMailDeliveryLogs() {
    var tbody = document.getElementById('mail_delivery_logs_tbody');
    var meta = document.getElementById('mail_delivery_logs_meta');
    var prev = document.getElementById('mail_delivery_logs_prev');
    var next = document.getElementById('mail_delivery_logs_next');
    if (!tbody) return;
    tbody.innerHTML = '<tr><td colspan="5" class="text-body-secondary small">Đang tải…</td></tr>';
    fetch('/admin/event/' + encodeURIComponent(eventId) + '/mail/delivery-logs?page=' + mailLogsPage + '&limit=' + mailLogsLimit)
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (!data.success) {
          tbody.innerHTML = '<tr><td colspan="5" class="text-danger small">' + (data.message || 'Lỗi') + '</td></tr>';
          return;
        }
        var rows = data.items || [];
        if (!rows.length) {
          tbody.innerHTML = '<tr><td colspan="5" class="text-body-secondary small">Chưa có dữ liệu. Bật Event Webhook trên SendGrid và gửi thử mail — hoặc chờ sự kiện <code>delivered</code> / <code>bounce</code>.</td></tr>';
        } else {
          tbody.innerHTML = rows
            .map(function (row) {
              return (
                '<tr><td class="text-nowrap small">' +
                escHtml(fmtTs(row.ts)) +
                '</td><td class="small">' +
                escHtml(row.to_email) +
                '</td><td class="small">' +
                escHtml(mailKindLabel(row.mail_kind)) +
                '</td><td class="small"><code>' +
                escHtml(row.event_type) +
                '</code><div class="text-body-secondary" style="font-size:0.75rem">' +
                escHtml(sgEventLabel(row.event_type)) +
                '</div></td><td class="small text-break">' +
                (row.reason ? escHtml(String(row.reason).slice(0, 400)) : '—') +
                '</td></tr>'
              );
            })
            .join('');
        }
        var total = data.total || 0;
        var pages = Math.max(1, Math.ceil(total / mailLogsLimit));
        if (meta) {
          meta.textContent = 'Tổng ' + total + ' dòng · Trang ' + data.page + '/' + pages;
        }
        if (prev) prev.disabled = data.page <= 1;
        if (next) next.disabled = data.page >= pages;
      })
      .catch(function () {
        tbody.innerHTML = '<tr><td colspan="5" class="text-danger small">Lỗi tải nhật ký.</td></tr>';
      });
  }
  var btnLogsRefresh = document.getElementById('btn_mail_logs_refresh');
  if (btnLogsRefresh) btnLogsRefresh.addEventListener('click', function () { loadMailDeliveryLogs(); });
  var btnLogsPrev = document.getElementById('mail_delivery_logs_prev');
  var btnLogsNext = document.getElementById('mail_delivery_logs_next');
  if (btnLogsPrev) {
    btnLogsPrev.addEventListener('click', function () {
      if (mailLogsPage > 1) {
        mailLogsPage -= 1;
        loadMailDeliveryLogs();
      }
    });
  }
  if (btnLogsNext) {
    btnLogsNext.addEventListener('click', function () {
      mailLogsPage += 1;
      loadMailDeliveryLogs();
    });
  }
  loadMailDeliveryLogs();
})();
</script>
