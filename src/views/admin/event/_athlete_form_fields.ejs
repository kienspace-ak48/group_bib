<% var p = typeof prefix !== 'undefined' ? prefix : 'manual'; %>

<div class="rounded border bg-white p-3 mb-2 row g-1">
    <!-- <div class="rounded border bg-white p-3 mb-2 row g-1"> -->
        <!-- ===== Thông tin cá nhân ===== -->
        <div class="col-12 mt-2">
            <h6 class="text-primary mb-1">Thông tin cá nhân</h6>
        </div>

        <div class="col-12 col-md-6">
            <label class="form-label small mb-0">Họ tên *</label>
            <input type="text" name="fullname" class="form-control form-control-sm <%= p %>-fullname" required />
        </div>

        <div class="col-12 col-md-6">
            <label class="form-label small mb-0">CCCD *</label>
            <input type="text" name="cccd" class="form-control form-control-sm <%= p %>-cccd" required />
        </div>

        <div class="col-12 col-md-4">
            <label class="form-label small mb-0">Điện thoại</label>
            <input type="text" name="phone" class="form-control form-control-sm <%= p %>-phone" />
        </div>

        <div class="col-12 col-md-5">
            <label class="form-label small mb-0">Email</label>
            <input type="email" name="email" class="form-control form-control-sm <%= p %>-email" />
        </div>

        <div class="col-12 col-md-3">
            <label class="form-label small mb-0">DOB<small>(mm/dd/yyyy)</small></label>
            <input type="date" name="dob" class="form-control form-control-sm <%= p %>-dob" />
        </div>

        <div class="col-12 col-md-2">
            <label class="form-label small mb-0">Giới tính</label>
            <select name="gender" class="form-select form-select-sm <%= p %>-gender">
                <option value="">—</option>
                <option value="M">Nam</option>
                <option value="F">Nữ</option>
            </select>
        </div>
    <!-- </div> -->

    <!-- <div class="rounded border bg-white p-3 mb-2 row g-1"> -->
        <!-- ===== Thông tin thi đấu ===== -->
        <div class="col-12 mt-2">
            <h6 class="text-success mb-1">Thông tin thi đấu</h6>
        </div>

        <div class="col-12 col-md-2">
            <label class="form-label small mb-0">BIB</label>
            <input type="text" name="bib" class="form-control form-control-sm <%= p %>-bib" />
        </div>

        <div class="col-12 col-md-3">
            <label class="form-label small mb-0">BIB name</label>
            <input type="text" name="bib_name" class="form-control form-control-sm <%= p %>-bib_name" />
        </div>

        <div class="col-12 col-md-3">
            <label class="form-label small mb-0">Hạng mục</label>
            <input type="text" name="category" class="form-control form-control-sm <%= p %>-category" />
        </div>

        <div class="col-12 col-md-2">
            <label class="form-label small mb-0">Item</label>
            <input type="text" name="item" class="form-control form-control-sm <%= p %>-item" />
        </div>

        <div class="col-12 col-md-2">
            <label class="form-label small mb-0">Zone</label>
            <input type="text" name="zone" class="form-control form-control-sm <%= p %>-zone" />
        </div>

        <div class="col-12 col-md-4">
            <label class="form-label small mb-0">Khung giờ nhận</label>
            <input
                type="text"
                name="pickup_time_range"
                class="form-control form-control-sm <%= p %>-pickup_time_range"
                placeholder="08:00 - 10:00"
            />
        </div>
    <!-- </div> -->

    <!-- <div class="rounded border bg-white p-3 mb-2 row g-1"> -->
        <!-- ===== Hệ thống ===== -->
        <div class="col-12 mt-2">
            <h6 class="text-secondary mb-1">Hệ thống</h6>
        </div>

        <div class="col-12 col-md-4">
            <label class="form-label small mb-0">QR code</label>
            <input
                type="text"
                name="qr_code"
                class="form-control form-control-sm <%= p %>-qr_code"
                placeholder="Để trống = dùng uid"
            />
        </div>

        <div class="col-12 col-md-2">
            <label class="form-label small mb-0">Chip</label>
            <input type="text" name="chip" class="form-control form-control-sm <%= p %>-chip" />
        </div>

        <div class="col-12 col-md-4">
            <label class="form-label small mb-0">Status</label>
            <select name="status" class="form-select form-select-sm <%= p %>-status">
                <option value="registered">registered</option>
                <option value="pending">pending</option>
                <option value="checked_in">checked_in</option>
                <option value="cancelled">cancelled</option>
            </select>
        </div>
    <!-- </div> -->
</div>
