<% var ev = typeof event !== 'undefined' ? event : {}; %>
<div class="card border-0 shadow-sm mb-4 <%= ws === 0 ? 'border-primary border-2' : '' %>">
  <div class="card-header d-flex justify-content-between align-items-center">
    <strong>1. Khởi tạo — Thông tin sự kiện</strong>
    <% if (ws === 0) { %><span class="badge bg-primary">Đang làm</span><% } %>
  </div>
  <div class="card-body">
    <form method="POST" action="/admin/event/<%= ev._id %>/update" class="row g-3">
      <div class="col-md-6">
        <label class="form-label">Tên</label>
        <input type="text" name="name" class="form-control" value="<%= ev.name || '' %>" />
      </div>
      <div class="col-md-6">
        <label class="form-label">Mã ngắn / Short ID</label>
        <input type="text" name="short_id" class="form-control" value="<%= ev.short_id || '' %>" />
      </div>
      <div class="col-12">
        <label class="form-label">Mô tả</label>
        <textarea name="desc" class="form-control" rows="3"><%= ev.desc || '' %></textarea>
      </div>
      <div class="col-md-6">
        <label class="form-label">Địa điểm</label>
        <input type="text" name="location" class="form-control" value="<%= ev.location || '' %>" />
      </div>
      <div class="col-md-3">
        <label class="form-label">Ngày bắt đầu</label>
        <input type="date" name="start_date" class="form-control" value="<%= isoDate(ev.start_date) %>" />
      </div>
      <div class="col-md-3">
        <label class="form-label">Ngày kết thúc</label>
        <input type="date" name="end_date" class="form-control" value="<%= isoDate(ev.end_date) %>" />
      </div>
      <div class="col-md-4">
        <label class="form-label">Loại giải</label>
        <input type="text" name="race_type" class="form-control" value="<%= ev.race_type || '' %>" placeholder="marathon / trail..." />
      </div>
      <div class="col-md-4">
        <label class="form-label">Trạng thái</label>
        <input type="text" name="status" class="form-control" value="<%= ev.status || '' %>" />
      </div>
      <div class="col-md-4 d-flex align-items-end">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" name="is_show" id="is_show" value="true" <%= ev.is_show ? 'checked' : '' %> />
          <label class="form-check-label" for="is_show">Hiển thị trên trang chủ (client)</label>
          <div class="form-text">Chỉ khi bật, sự kiện mới xuất hiện trong danh sách công khai; không đăng dữ liệu quản trị / check-in.</div>
        </div>
      </div>
      <div class="col-md-6">
        <label class="form-label">Ban tổ chức</label>
        <input type="text" name="organizer_name" class="form-control" value="<%= ev.organizer_name || '' %>" />
      </div>
      <div class="col-md-6">
        <label class="form-label">Website</label>
        <input type="url" name="organizer_web" class="form-control" value="<%= ev.organizer_web || '' %>" />
      </div>
      <div class="col-md-6">
        <label class="form-label">Fanpage</label>
        <input type="url" name="organizer_fanpage" class="form-control" value="<%= ev.organizer_fanpage || '' %>" />
      </div>
      <div class="col-md-6">
        <label class="form-label">Zalo</label>
        <input type="text" name="organizer_zalo" class="form-control" value="<%= ev.organizer_zalo || '' %>" />
      </div>
      <div class="col-12">
        <label class="form-label d-block mb-2">Check-in tại quầy (tool check-in)</label>
        <div class="text-body-secondary small mb-2">Chọn yêu cầu khi nhân viên xác nhật check-in cho VĐV.</div>
        <% var _cap = ev.checkin_capture_mode || 'both'; %>
        <div class="d-flex flex-column gap-2">
          <div class="form-check">
            <input class="form-check-input" type="radio" name="checkin_capture_mode" id="cap_none" value="none" <%= _cap === 'none' ? 'checked' : '' %> />
            <label class="form-check-label" for="cap_none">Chỉ xác nhận check-in — không bắt buộc chữ ký và không chụp ảnh</label>
          </div>
          <div class="form-check">
            <input class="form-check-input" type="radio" name="checkin_capture_mode" id="cap_sig" value="signature" <%= _cap === 'signature' ? 'checked' : '' %> />
            <label class="form-check-label" for="cap_sig">Bắt buộc chữ ký (không bắt buộc ảnh)</label>
          </div>
          <div class="form-check">
            <input class="form-check-input" type="radio" name="checkin_capture_mode" id="cap_photo" value="photo" <%= _cap === 'photo' ? 'checked' : '' %> />
            <label class="form-check-label" for="cap_photo">Bắt buộc chụp ảnh (không bắt buộc chữ ký)</label>
          </div>
          <div class="form-check">
            <input class="form-check-input" type="radio" name="checkin_capture_mode" id="cap_both" value="both" <%= _cap === 'both' ? 'checked' : '' %> />
            <label class="form-check-label" for="cap_both">Bắt buộc cả chữ ký và ảnh chụp</label>
          </div>
        </div>
      </div>
      <div class="col-12 border-top pt-3 mt-2">
        <label class="form-label d-block mb-2">Ký miễn trừ online trước (sau đó mới gửi mail QR)</label>
        <div class="text-body-secondary small mb-2">
          Bật khi BTC muốn: gửi mail <strong>mời ký miễn trừ</strong> (không có QR) → VĐV ký trên web → hệ thống gửi mail <strong>QR nhận BIB</strong>.
          Tại quầy check-in, nếu VĐV đã ký online, hệ thống <strong>không bắt buộc chữ ký</strong> lần nữa (vẫn có thể bắt buộc chụp ảnh theo cấu hình bên trên).
        </div>
        <% var _ow = ev.online_waiver_first_flow === true; %>
        <div class="form-check mb-2">
          <input class="form-check-input" type="checkbox" name="online_waiver_first_flow" id="online_waiver_first_flow" value="true" <%= _ow ? 'checked' : '' %> />
          <label class="form-check-label" for="online_waiver_first_flow">Bật luồng ký miễn trừ online trước khi gửi QR</label>
        </div>
        <div class="row g-2">
          <div class="col-12">
            <label class="form-label small">Link file miễn trừ (PDF/DOC…) hiển thị cho VĐV</label>
            <input type="url" name="waiver_document_url" class="form-control form-control-sm" value="<%= ev.waiver_document_url || '' %>" placeholder="https://..." />
          </div>
          <div class="col-12">
            <label class="form-label small">Nội dung thông báo trên trang ký (HTML đơn giản)</label>
            <textarea name="waiver_notice_html" class="form-control form-control-sm" rows="4" placeholder="Đoạn giới thiệu / điều khoản…"><%= ev.waiver_notice_html || '' %></textarea>
            <div class="form-text">Dùng cho trang công khai sau khi VĐV mở link trong email mời ký.</div>
          </div>
        </div>
      </div>
      <div class="col-12">
        <label class="form-label d-block mb-2">Ủy quyền đơn (link trong mail QR)</label>
        <div class="text-body-secondary small mb-2">
          Khi bật, mail gửi QR (hàng loạt / thủ công) có thêm nút dẫn tới trang công khai để người nhận hộ điền thông tin (một VĐV — một link bí mật).”.
        </div>
        <% var _sd = ev.single_delegation_enabled !== false; %>
        <div class="form-check">
          <input class="form-check-input" type="checkbox" name="single_delegation_enabled" id="single_delegation_enabled" value="true" <%= _sd ? 'checked' : '' %> />
          <label class="form-check-label" for="single_delegation_enabled">Cho phép ủy quyền đơn qua link trong mail</label>
          <div class="form-text">Mặc định bật. Tắt nếu sự kiện chỉ dùng ủy quyền nhóm do BTC nhập.</div>
        </div>
      </div>
      <div class="col-12">
        <button type="submit" class="btn btn-primary">Lưu thông tin</button>
      </div>
    </form>
  </div>
</div>
