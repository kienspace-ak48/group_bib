<style>
  /* Desktop default */
  .banner-content h2 {
    font-size: 40px; /* tiêu đề lớn */
  }
  .banner-content p {
    font-size: 20px; /* chữ mô tả */
  }
  .banner-content button {
    font-size: 16px;
  }
  section h3 {
    font-size: 32px;
  }
  section p {
    font-size: 18px;
  }

  /* ============= HERO SECTION ============= */
  .banner {
    height: calc(100vh - 80px);
    background: url("/imgs/ar-hero.jpg") center/cover no-repeat;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
  }
  .banner::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.18);
  }
  .banner-content h2,
  .banner-content p {
    color: #fff;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.85);
    font-weight: 700;
  }
  .banner-content {
    background: rgba(0, 0, 0, 0.15);
    position: relative;
    z-index: 1;
    max-width: 750px;
    padding: 0 20px;
  }

  .banner-content h2 {
    margin-bottom: 20px;
    text-transform: uppercase;
    animation: fadeInUp 1s ease forwards;
  }
  .banner-content p {
    margin-bottom: 30px;
    animation: fadeInUp 1.5s ease forwards;
    font-weight: 400;
    line-height: 28px;
  }
  .banner-content button {
    background: #ffcc00;
    border: none;
    padding: 14px 28px;
    font-weight: bold;
    cursor: pointer;
    transition: 0.3s;
    animation: fadeInUp 2s ease forwards;
    border-radius: 6px;
  }
  .banner-content button:hover {
    background: #ff9900;
    transform: scale(1.05);
  }

  /* Animation */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ============= SECTION ============= */
  section {
    padding: 70px 20px;
    text-align: center;
    background: #fff;
    color: #333;
  }
  section p {
    max-width: 700px;
    margin: 0 auto;
    line-height: 28px;
  }

  /* ============= RESPONSIVE ============= */
  @media (max-width: 768px) {
    .banner-content h2 {
      font-size: 28px;
    }
    .banner-content p {
      font-size: 16px;
      line-height: 24px;
    }
    .banner-content button {
      font-size: 14px;
    }
    section h3 {
      font-size: 26px;
    }
    section p {
      font-size: 16px;
    }
  }

  /* ============= ROAD EVENTS LIST ============= */
  .road-events {
    padding: 56px 20px 70px;
    background: #f0f0f8;
    text-align: left;
  }
  .road-events__inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .road-events__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .road-events__title {
    font-size: 28px;
    font-weight: 800;
    color: #1e3a5f;
    margin: 0;
    position: relative;
    padding-bottom: 8px;
  }
  .road-events__title::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 48px;
    height: 3px;
    background: #1e3a5f;
    border-radius: 2px;
  }
  .road-events__more {
    color: #5c6470;
    font-size: 15px;
    text-decoration: none;
    font-weight: 500;
    white-space: nowrap;
  }
  .road-events__more:hover {
    color: #1e3a5f;
  }
  .road-events__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 28px;
  }
  .road-events__filter-btn {
    border: none;
    cursor: pointer;
    padding: 10px 18px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 600;
    background: #e8e9f0;
    color: #4a5568;
    transition: background 0.2s, color 0.2s;
  }
  .road-events__filter-btn.is-active {
    background: #1e3a5f;
    color: #fff;
  }
  .road-events__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  @media (max-width: 900px) {
    .road-events__grid {
      grid-template-columns: 1fr;
    }
  }
  .event-card {
    display: flex;
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(30, 58, 95, 0.08);
    overflow: hidden;
    min-height: 160px;
  }
  .event-card__thumb {
    width: 180px;
    min-width: 140px;
    flex-shrink: 0;
    background: #e2e8f0;
  }
  .event-card__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .event-card__body {
    flex: 1;
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .event-card__title {
    font-size: 17px;
    font-weight: 700;
    color: #1a202c;
    margin: 0 0 10px;
    line-height: 1.35;
  }
  .event-card__meta {
    font-size: 13px;
    color: #64748b;
    margin-bottom: 6px;
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }
  .event-card__meta i {
    margin-top: 2px;
    flex-shrink: 0;
  }
  .event-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 10px 0 12px;
  }
  .event-card__tag {
    font-size: 11px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }
  .event-card__tag--road {
    background: #f37021;
    color: #fff;
  }
  .event-card__tag--dist {
    background: #e8e9f0;
    color: #4a5568;
  }
  .event-card__footer {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }
  .event-card__footer-left {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    flex: 1;
    min-width: 0;
  }
  .event-card__footer .event-card__cta {
    margin-left: auto;
  }
  .event-card__stats {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 13px;
    color: #64748b;
  }
  .event-card__stats .text-amber {
    color: #f59e0b;
  }
  .event-card__social {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .event-card__social a {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #2563eb;
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    text-decoration: none;
  }
  .event-card__social a:hover {
    opacity: 0.9;
  }
  .event-card__cta {
    border: none;
    border-radius: 999px;
    padding: 10px 20px;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.04em;
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
  }
  .event-card__cta--register {
    background: #ff2d81;
    color: #fff;
  }
  .event-card__cta--view {
    background: #4f56d1;
    color: #fff;
  }
  .road-events__empty {
    text-align: center;
    padding: 40px 20px;
    color: #64748b;
    font-size: 15px;
  }
</style>

<link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css"
/>

<div class="banner">
  <div class="banner-content">
    <h2><%=hp.hero_title%></h2>
    <p>
      <%-hp.hero_desc%>
    </p>
    <!-- Optimizing every race – from management, timing, to athlete experience. -->
    <button onclick="scrollToSection('about')">Explore now</button>
  </div>
</div> 


<section id="main" class="road-events">
  <% 
    const formatEventDates = (start, end) => {
      if (!start) return '';
      const s = new Date(start);
      if (Number.isNaN(s.getTime())) return '';
      if (!end) {
        return s.toLocaleDateString('vi-VN', { day: '2-digit', month: 'long', year: 'numeric' });
      }
      const e = new Date(end);
      if (Number.isNaN(e.getTime())) {
        return s.toLocaleDateString('vi-VN', { day: '2-digit', month: 'long', year: 'numeric' });
      }
      if (s.getMonth() === e.getMonth() && s.getFullYear() === e.getFullYear()) {
        return s.getDate() + ' - ' + e.getDate() + ' tháng ' + String(s.getMonth() + 1).padStart(2, '0') + ', ' + s.getFullYear();
      }
      return s.toLocaleDateString('vi-VN') + ' – ' + e.toLocaleDateString('vi-VN');
    };
    const monthKeyFromDate = (start) => {
      if (!start) return '';
      const d = new Date(start);
      if (Number.isNaN(d.getTime())) return '';
      return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0');
    };
    const raceLabel = (raceType) => {
      if (!raceType) return 'ROAD';
      const map = { marathon: 'ROAD', trail: 'TRAIL', virtual: 'VIRTUAL' };
      return map[raceType] || String(raceType).toUpperCase();
    };
    var _events = locals.events || [];
    var _months = locals.eventMonths || [];
  %>
  <div class="road-events__inner">
    <div class="road-events__head">
      <h2 class="road-events__title">Các giải Road</h2>
      <a href="#main" class="road-events__more">Xem thêm →</a>
    </div>

    <% if (_months.length) { %>
    <div class="road-events__filters" role="tablist" aria-label="Lọc theo tháng">
      <button type="button" class="road-events__filter-btn is-active" data-event-filter="all">Tất cả</button>
      <% _months.forEach(function (m) { %>
      <button type="button" class="road-events__filter-btn" data-event-filter="<%= m.key %>"><%= m.label %></button>
      <% }); %>
    </div>
    <% } %>

    <% if (!_events.length) { %>
    <p class="road-events__empty">Hiện chưa có sự kiện nào được hiển thị.</p>
    <% } else { %>
    <div class="road-events__grid" id="road-events-grid">
      <% _events.forEach(function (ev) { 
           const mk = monthKeyFromDate(ev.start_date);
           const thumb = ev.img_thumb || ev.img_banner || '/imgs/ar-hero.jpg';
           const isTicket = ev.race_function === 'ticket';
      %>
      <article class="event-card event-card-item" data-month-key="<%= mk %>">
        <div class="event-card__thumb">
          <img src="<%= thumb %>" alt="<%= ev.name || 'Sự kiện' %>" loading="lazy" />
        </div>
        <div class="event-card__body">
          <h3 class="event-card__title"><%= ev.name || 'Sự kiện' %></h3>
          <div class="event-card__meta">
            <i class="far fa-calendar-alt" aria-hidden="true"></i>
            <span><%= formatEventDates(ev.start_date, ev.end_date) %></span>
          </div>
          <div class="event-card__meta">
            <i class="fas fa-map-marker-alt" aria-hidden="true"></i>
            <span><%= ev.location || '—' %></span>
          </div>
          <div class="event-card__tags">
            <span class="event-card__tag event-card__tag--road"><%= raceLabel(ev.race_type) %></span>
          </div>
          <div class="event-card__footer">
            <div class="event-card__footer-left">
              <div class="event-card__stats">
                <span><i class="fas fa-star text-amber"></i> 5/5</span>
                <span><i class="far fa-comment"></i> 0 bình luận</span>
              </div>
              <div class="event-card__social">
                <% if (ev.organizer_fanpage) { %>
                <a href="<%= ev.organizer_fanpage %>" target="_blank" rel="noopener noreferrer" title="Facebook" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
                <% } %>
                <% if (ev.organizer_web) { %>
                <a href="<%= ev.organizer_web %>" target="_blank" rel="noopener noreferrer" title="Website" aria-label="Website"><i class="fas fa-globe"></i></a>
                <% } %>
              </div>
            </div>
            <% if (isTicket) { %>
            <a class="event-card__cta event-card__cta--register" href="/event/event-detail/<%= ev.slug %>">ĐĂNG KÝ</a>
            <% } else { %>
            <a class="event-card__cta event-card__cta--view" href="/event/event-detail/<%= ev.slug %>">XEM SỰ KIỆN</a>
            <% } %>
          </div>
        </div>
      </article>
      <% }); %>
    </div>
    <% } %>
  </div>
</section>

<script>
  function scrollToSection(id) {
    document.getElementById(id).scrollIntoView({ behavior: "smooth" });
  }

  (function roadEventsFilter() {
    var grid = document.getElementById("road-events-grid");
    if (!grid) return;
    var cards = grid.querySelectorAll(".event-card-item");
    var buttons = document.querySelectorAll("[data-event-filter]");
    function applyFilter(v) {
      cards.forEach(function (card) {
        var mk = card.getAttribute("data-month-key");
        var show = v === "all" || mk === v;
        card.style.display = show ? "" : "none";
      });
      buttons.forEach(function (b) {
        b.classList.toggle("is-active", b.getAttribute("data-event-filter") === v);
      });
    }
    buttons.forEach(function (btn) {
      btn.addEventListener("click", function () {
        applyFilter(btn.getAttribute("data-event-filter"));
      });
    });
    applyFilter("all");
  })();
</script>