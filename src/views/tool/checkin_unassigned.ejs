<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Check-in | Chưa gán sự kiện</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light d-flex align-items-center min-vh-100">
    <div class="container text-center py-5">
        <h1 class="h4 mb-3">Tài khoản check-in chưa được gán sự kiện</h1>
        <% if (typeof message !== 'undefined' && message) { %>
        <p class="text-secondary"><%= message %></p>
        <% } else { %>
        <p class="text-secondary">Liên hệ quản trị viên để gán sự kiện cho tài khoản này.</p>
        <% } %>
        <a class="btn btn-outline-primary mt-2" href="/auth/normal/admin/logout">Đăng xuất</a>
    </div>
</body>
</html>
