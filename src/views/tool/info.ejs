                                </h3>

                                <div class="space-y-6 grid grid-cols-2">
                                    <div class="space-y-1 mb-4">
                                                <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Phone</p>

                                                <p class="text-sm font-medium text-gray-900 tracking-wider group-hover:text-indigo-700 transition-colors">
                                                    <%= pc.phone || 'N/A' %>
