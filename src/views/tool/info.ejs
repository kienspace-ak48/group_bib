<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= typeof event !== 'undefined' && event && event.name ? event.name : 'Check-in' %> · Chi tiết VĐV</title>
    <script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<script
    src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"
    integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r"
    crossorigin="anonymous"
></script>
<script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.min.js"
    integrity="sha384-G/EV+4j2dNv+tEPo3++6LCgdCROaejBqfUeNjuKAiuXbjrxilcCdDz6ZAVfHWe1Y"
    crossorigin="anonymous"
></script>
<style>
    * {
        font-family: 'Inter', sans-serif;
    }
    .header-gradient {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
    .badge-warning {
        background-color: #fef3c7;
        color: #92400e;
    }
    .badge-success {
        background-color: #d1fae5;
        color: #065f46;
    }
</style>
</head>
<body class="bg-gray-50">
    <div class="">
        <!-- Main Content -->
        <main class="m-auto mx-auto px-4 py-6 max-w-5xl">
            <% var capMode = (typeof event !== 'undefined' && event && event.checkin_capture_mode) ? event.checkin_capture_mode : 'both'; %>
            <% var showSig = (capMode === 'signature' || capMode === 'both'); %>
            <% var showPhoto = (capMode === 'photo' || capMode === 'both'); %>
            <div class="flex flex-col gap-6">
                <!-- Athlete Profile Card -->
                <div class="bg-white rounded-2xl shadow-lg overflow-hidden border border-gray-100">
                    <!-- Header with gradient & status -->
                    <div class="bg-gradient-to-r from-indigo-600 to-purple-600 p-4 sm:p-5 md:p-6">
                        <% var _checkedIn = (pc.status === 'checked_in' || pc.checkin_status === true); %>
                        <h2 class="text-lg sm:text-xl md:text-2xl font-bold text-white mb-3 sm:mb-4 tracking-tight leading-snug"><%= event.name %></h2>
                        <div class="rounded-2xl border border-white/25 bg-white/10 backdrop-blur-md px-3 py-3 sm:px-4 sm:py-3.5 md:px-5 md:py-4 shadow-inner shadow-black/10">
                            <div class="flex flex-col gap-3 md:flex-row md:items-center md:gap-5 md:min-w-0">
                                <!-- Category + Zone: full width, wrap — không truncate -->
                                <div class="min-w-0 flex-1 md:min-w-[40%]">
                                    <p class="text-[12px] sm:text-[13px] font-semibold uppercase tracking-wider text-white/60 mb-1">Category: <span class="text-white text-[12px] sm:text-[13px] font-semibold leading-snug break-words [overflow-wrap:anywhere]"><%= pc.category || '—' %></span></p>
                                    <% 
                                      var _z = pc.zone != null && String(pc.zone).trim() !== '' ? String(pc.zone).trim() : '';
                                      var _zLower = _z.toLowerCase();
                                      var zoneLabel = '—';
                                      if (_z) {
                                        zoneLabel = (_zLower === 'earlybib' || _zLower === '1') ? 'Early BIB' : _z;
                                      }
                                    %>
                                    <p class="text-[12px] sm:text-[13px] font-semibold uppercase tracking-wider text-white/60 mt-2 sm:mt-1.5">Zone: <span class="text-white text-[12px] sm:text-[13px] font-semibold leading-snug break-words [overflow-wrap:anywhere]"><%= zoneLabel %></span></p>
                                </div>
                                <!-- Code + trạng thái: cùng hàng (mobile), md+ dính nhóm bên phải -->
                                <div class="flex flex-row flex-wrap items-center justify-between gap-3 sm:gap-4 md:flex-nowrap md:justify-end md:gap-4 md:shrink-0">
                                    <div class="flex min-w-0 items-baseline gap-2 border-t border-white/20 pt-2.5 md:border-t-0 md:border-l md:border-white/25 md:pt-0 md:pl-4">
                                        <span class="text-[12px] sm:text-[13px] font-semibold uppercase tracking-wider text-white/60 shrink-0">Code</span>
                                        <span class="text-amber-200 text-lg sm:text-xl md:text-2xl font-bold tabular-nums tracking-tight"><%= pc.bib || '—' %></span>
                                    </div>
                                    <% if (_checkedIn) { %>
                                    <div class="inline-flex flex-row items-center gap-2 sm:gap-2.5 rounded-xl border border-emerald-300/35 bg-emerald-500/15 px-2.5 py-2 sm:px-3 sm:py-2.5 text-white shadow-md shadow-black/10">
                                        <span class="flex h-8 w-8 sm:h-9 sm:w-9 shrink-0 items-center justify-center rounded-lg bg-emerald-400/25 ring-1 ring-white/20">
                                            <i class="fas fa-check-circle text-emerald-100 text-base sm:text-lg" aria-hidden="true"></i>
                                        </span>
                                        <span class="font-semibold text-[11px] sm:text-sm whitespace-nowrap leading-tight">Đã check-in</span>
                                    </div>
                                    <% } else { %>
                                    <div class="inline-flex flex-row items-center gap-2 sm:gap-2.5 rounded-xl border border-amber-300/35 bg-amber-500/15 px-2.5 py-2 sm:px-3 sm:py-2.5 text-white shadow-md shadow-black/10">
                                        <span class="flex h-8 w-8 sm:h-9 sm:w-9 shrink-0 items-center justify-center rounded-lg bg-amber-400/25 ring-1 ring-white/20">
                                            <i class="fas fa-hourglass-half text-amber-100 text-base sm:text-lg" aria-hidden="true"></i>
                                        </span>
                                        <span class="font-semibold text-[11px] sm:text-sm whitespace-nowrap leading-tight">Chưa check-in</span>
                                    </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Body: Two-column layout – Improved Style Only -->
                    <div class="p-6 md:p-8 lg:p-10 bg-gradient-to-b from-white to-gray-50/50 rounded-2xl border border-gray-100 shadow-sm">
                        <div class="">
                            <!-- PERSONAL INFORMATION -->
                            <div class="space-y-3">
                                <h3 class="text-sm font-bold text-gray-800 pb-3 border-b-2 border-indigo-200/70 flex items-center gap-3">
                                    <i class="fas fa-user-edit text-indigo-600 text-sm opacity-90"></i>
                                    Personal Information
                                </h3>
                                <input id="code_hidden" type="hidden" value="<%= pc.uid %>" />
                                <% if (typeof returnTo !== 'undefined' && returnTo) { %>
                                <input type="hidden" id="return_to" value="<%= returnTo %>" />
                                <% } %>
                                <% if (typeof checkinViaGroupId !== 'undefined' && checkinViaGroupId) { %>
                                <input type="hidden" id="checkin_via_group_id" value="<%= checkinViaGroupId %>" />
                                <% } %>

        <div class="grid grid-cols-2 gap-4">
            <!-- LEFT -->
            <div>
                <div class="space-y-1 mb-4">
                    <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">
                        Họ tên / Fullname
                    </p>
                    <p class="text-sm font-semibold text-gray-900 leading-5">
                        <%= pc.fullname %>
                    </p>
                </div>

                <div class="space-y-1 mb-4">
                    <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">
                        VẬT PHẨM / ITEM
                    </p>
                    <p class="text-sm font-semibold text-gray-900 leading-5">
                        <%= pc.item || 'N/A' %>
                    </p>
                </div>

                <div class="space-y-1 mb-4">
                    <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">
                        NICKNAME
                    </p>
                    <p class="text-sm font-semibold text-gray-900 leading-5">
                        <%= pc.bib_name || 'N/A' %>
                    </p>
                </div>
            </div>

            <!-- RIGHT -->
            <div>
                <div class="space-y-1 mb-4">
                    <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">
                        Giới tính / Gender
                    </p>
                    <p class="text-sm font-semibold text-gray-900 leading-5">
                        <%= pc.gender === true || pc.gender === 1 ? 'Male' : (pc.gender === false || pc.gender === 0 ? 'Female' : 'N/A') %>
                    </p>
                </div>

                <div class="space-y-1 mb-4">
                    <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">
                        CCCD / ID
                    </p>
                    <p class="text-sm font-semibold text-gray-900 leading-5">
                        <%= pc.cccd || 'N/A' %>
                    </p>
                </div>

                <div class="space-y-1 mb-4">
                    <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">
                        Ngày Sinh / DOB
                    </p>
                    <% var dformat = pc.dob ? new Date(pc.dob).toLocaleDateString('vi-VN') : 'N/A' %>
                    <p class="text-sm font-semibold text-gray-900 leading-5">
                        <%= dformat %>
                    </p>
                </div>
            </div>
        </div>
                            </div>

                            <!-- CONTACT INFORMATION -->
                            <div class="space-y-3">
                                <h3 class="text-sm font-bold text-gray-800 pb-3 border-b-2 border-indigo-200/70 flex items-center gap-3">
                                    <i class="fas fa-address-card text-purple-600 text-sm opacity-90"></i>
                                    Contact Information
                                </h3>

                                <div class="grid grid-cols-[2fr_1fr] no-wrap gap-x-8 gap-y-4 items-start">
                                    <div class="flex flex-col gap-1.5 min-h-[4rem]">
                                        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Email</p>
                                        <p class="text-sm font-semibold text-gray-900 break-all leading-relaxed">
                                            <%= pc.email || 'N/A' %>
                                        </p>
                                    </div>
                                    <div class="flex flex-col gap-1.5 min-h-[4rem]">
                                        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Phone</p>
                                        <p class="text-sm font-semibold text-gray-900 break-words leading-relaxed">
                                            <%= pc.phone || 'N/A' %>
                                        </p>
                                    </div>
                                    
                                </div>
                            </div>
                            <% if (_checkedIn && (pc.checkin_signature_path || pc.checkin_photo_path)) { %>
                            <div class="space-y-3">
                                <h3 class="text-sm font-bold text-gray-800 pb-3 border-b-2 border-indigo-200/70 flex items-center gap-3">
                                    <i class="fas fa-camera text-purple-600 text-sm opacity-90"></i>
                                    Đã lưu khi check-in
                                </h3>
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 items-stretch">
                                    <% if (pc.checkin_signature_path) { %>
                                    <div class="flex flex-col gap-2 min-h-0">
                                        <p class="text-xs font-semibold uppercase tracking-wide text-gray-500 leading-none h-5 flex items-end">Chữ ký</p>
                                        <div class="flex flex-1 min-h-[200px] sm:min-h-[240px] items-center justify-center rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
                                            <img
                                                src="<%= pc.checkin_signature_path %>"
                                                alt="Chữ ký đã lưu"
                                                class="max-h-[220px] w-full max-w-full object-contain object-center"
                                            />
                                        </div>
                                    </div>
                                    <% } %>
                                    <% if (pc.checkin_photo_path) { %>
                                    <div class="flex flex-col gap-2 min-h-0">
                                        <p class="text-xs font-semibold uppercase tracking-wide text-gray-500 leading-none h-5 flex items-end">Ảnh chụp</p>
                                        <div class="flex flex-1 min-h-[200px] sm:min-h-[240px] items-center justify-center rounded-xl border border-gray-200 bg-slate-100 p-2 shadow-sm overflow-hidden">
                                            <img
                                                src="<%= pc.checkin_photo_path %>"
                                                alt="Ảnh check-in đã lưu"
                                                class="max-h-[min(55vh,320px)] w-full h-auto object-contain object-center"
                                                style="image-rendering: auto;"
                                            />
                                        </div>
                                    </div>
                                    <% } %>
                                </div>
                            </div>
                            <% } %>

                            <% if (!_checkedIn) { %>
                            <input type="hidden" id="capture_mode" value="<%= capMode %>" />
                            <div class="space-y-3 mt-6">
                                <h3 class="text-sm font-bold text-gray-800 pb-3 border-b-2 border-indigo-200/70 flex items-center gap-3">
                                    <i class="fas fa-signature text-purple-600 text-sm opacity-90"></i>
                                    Check-in
                                </h3>
                                <% if (capMode === 'none') { %>
                                <p class="text-sm text-gray-600">Giải này chỉ cần xác nhận check-in (không thu chữ ký / ảnh). Nhấn <strong>Hoàn tất check-in</strong> bên dưới.</p>
                                <% } else if (capMode === 'both') { %>
                                <p class="text-sm text-gray-600">Ký bên trái, chụp ảnh bên phải, sau đó nhấn <strong>Hoàn tất check-in</strong>.</p>
                                <% } else if (capMode === 'signature') { %>
                                <p class="text-sm text-gray-600">Yêu cầu <strong>chữ ký</strong>, sau đó nhấn <strong>Hoàn tất check-in</strong>.</p>
                                <% } else if (capMode === 'photo') { %>
                                <p class="text-sm text-gray-600">Yêu cầu <strong>chụp ảnh</strong> người tham gia, sau đó nhấn <strong>Hoàn tất check-in</strong>.</p>
                                <% } %>
                                <% if (capMode !== 'none') { %>
                                <div class="grid grid-cols-1 <%= showSig && showPhoto ? 'md:grid-cols-2' : '' %> gap-4 items-stretch">
                                    <% if (showSig) { %>
                                    <div class="flex flex-col min-w-0">
                                        <p class="text-xs font-medium text-gray-500 mb-1">Chữ ký</p>
                                        <div class="rounded-xl border border-gray-200 bg-white overflow-hidden h-[200px] w-full">
                                            <canvas id="signature-pad" class="w-full h-full touch-none block cursor-crosshair"></canvas>
                                        </div>
                                        <button type="button" id="btn_clear_sig" class="mt-2 px-4 py-2 rounded-lg border border-gray-300 text-sm font-medium hover:bg-gray-50 self-start">Xóa chữ ký</button>
                                    </div>
                                    <% } %>
                                    <% if (showPhoto) { %>
                                    <div class="flex flex-col min-w-0">
                                        <p class="text-xs font-medium text-gray-500 mb-1">Ảnh người tham gia</p>
                                        <div id="photo_preview_wrap" class="rounded-xl border border-dashed border-gray-300 bg-gray-50 h-[200px] w-full flex items-center justify-center overflow-hidden relative">
                                            <span id="photo_placeholder" class="text-sm text-gray-400 text-center px-3">Nhấn <strong>Chụp ảnh</strong> bên dưới</span>
                                            <img id="inline_photo_preview" class="hidden w-full h-full object-cover" alt="Ảnh đã chụp" />
                                        </div>
                                        <button type="button" id="btn_open_camera" class="mt-2 px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700 self-start">
                                            <i class="fas fa-camera mr-1"></i> Chụp ảnh
                                        </button>
                                    </div>
                                    <% } %>
                                </div>
                                <% } %>
                                <p id="photo_status" class="text-sm text-green-600 hidden"><i class="fas fa-check-circle"></i> Đã có ảnh chụp.</p>
                                <p id="checkin_err" class="text-sm text-red-600 hidden"></p>
                            </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                 <div class="w-full mx-auto">
                    <div class="grid grid-cols-2 gap-4">
                        <% if (typeof returnTo !== 'undefined' && returnTo) { %>
                        <!-- <a href="<%#= returnTo %>" class="flex-1 max-w-xs">
                            <button type="button" class="w-full bg-slate-600 hover:bg-slate-700 text-white font-bold px-3 py-2 rounded-xl transition flex items-center justify-center shadow-sm">
                                <i class="fas fa-users mr-2"></i>
                                Quay lại danh sách nhóm
                            </button>
                        </a> -->
                        <% } %>
                        <button
                            type="button"
                            id="btn_back_checkin"
                            class="flex-1 max-w-xs bg-gray-700 hover:bg-gray-800 text-white font-bold px-3 py-2 rounded-xl transition flex items-center justify-center shadow-sm"
                        >
                            <i class="fas fa-arrow-left mr-2"></i>
                            Back
                        </button>
    
                        <% if (!_checkedIn) { %>
                        <button
                            type="button"
                            id="btn_submit_checkin"
                            class="flex-1 max-w-xs bg-green-600 hover:bg-green-700 text-white font-bold px-3 py-2 rounded-xl transition flex items-center justify-center shadow-md active:scale-95"
                        >
                            <i class="fas fa-check-circle mr-2"></i>
                            Hoàn tất check-in
                        </button>
                        <% } %>
                    </div>
                 </div>
        
            </div>
        </main>
    </div>

    <!-- ==============MODAL (chỉ khi giải yêu cầu ảnh) =============== -->
    <% if (showPhoto) { %>
    <div id="modal" class="fixed inset-0 bg-black/50 flex items-center justify-center hidden z-[100]">
        <!-- Modal box -->
        <div class="bg-white rounded-xl w-full max-w-md p-6 transform transition-all scale-95 opacity-0" id="modalBox">
            <!-- Header -->
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-lg font-semibold">Chụp ảnh</h2>
