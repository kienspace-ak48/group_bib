    <script src="https://cdn.jsdelivr.net/npm/signature_pad@4.1.7/dist/signature_pad.umd.min.js"></script>
    <script>
        /** Mở từ tool check-in (cửa sổ popup): đóng và refresh tab check-in — không load /tool-checkin trong tab phụ */
        function checkinToolCloseAndRefreshOpener() {
            if (window.opener && !window.opener.closed) {
                try {
                    window.opener.location.reload();
                } catch (e) {}
                window.close();
                return true;
            }
            return false;
        }
        function checkinToolGoBack() {
            if (checkinToolCloseAndRefreshOpener()) return;
            var retEl = document.getElementById('return_to');
            if (retEl && retEl.value) {
                window.location.href = retEl.value;
                return;
            }
            window.location.href = '/tool-checkin';
        }

        document.addEventListener('DOMContentLoaded', function () {
            let stream;
            let photoBlob = null;
            var capModeEl = document.getElementById('capture_mode');
            var capMode = capModeEl ? capModeEl.value : 'both';
            const modal = document.getElementById('modal');
            const modalBox = document.getElementById('modalBox');
            const video = document.querySelector('#video');
            const capCanvas = document.querySelector('#canvas');
            const preview = document.querySelector('#preview');
            const btnCaptureCamera = document.querySelector('#capture');
            const btnRetake = document.querySelector('#recapture');
            const btnCaptureConfirm = document.querySelector('#capture_confirm');
            const btnSubmit = document.querySelector('#btn_submit_checkin');
            const sigCanvas = document.getElementById('signature-pad');
            const btnClearSig = document.getElementById('btn_clear_sig');
            const btnOpenCamera = document.getElementById('btn_open_camera');
            const photoStatus = document.getElementById('photo_status');
            const errEl = document.getElementById('checkin_err');
            const inlinePhotoPreview = document.getElementById('inline_photo_preview');
            const photoPlaceholder = document.getElementById('photo_placeholder');
            const cameraBox = document.getElementById('cameraBox');
            const previewBox = document.getElementById('previewBox');
            const btnModalCloseX = document.getElementById('modal_close_x');
            const btnBackCheckin = document.getElementById('btn_back_checkin');
            if (btnBackCheckin) {
                btnBackCheckin.addEventListener('click', function () {
                    checkinToolGoBack();
                });
            }

            let signaturePad = null;
            var inlinePhotoObjectUrl = null;

            function dataURLToBlob(dataUrl) {
                try {
                    var parts = dataUrl.split(',');
                    var mime = (parts[0].match(/:(.*?);/) || [null, 'image/png'])[1];
                    var bstr = atob(parts[1] || '');
                    var n = bstr.length;
                    var u8 = new Uint8Array(n);
                    while (n--) u8[n] = bstr.charCodeAt(n);
                    return new Blob([u8], { type: mime });
                } catch (e) {
                    return null;
                }
            }

            /** Xuất PNG từ SignaturePad: toBlob trước, fallback toDataURL (Safari / canvas nhỏ). */
            function getSignatureBlob(callback) {
                if (!signaturePad) {
                    callback(null);
                    return;
                }
                try {
                    signaturePad.toBlob(function (blob) {
                        if (blob && blob.size > 0) {
                            callback(blob);
                            return;
                        }
                        var url = signaturePad.toDataURL('image/png');
                        var b = dataURLToBlob(url);
                        callback(b && b.size > 0 ? b : null);
                    }, 'image/png');
                } catch (e) {
                    try {
                        var url2 = signaturePad.toDataURL('image/png');
                        var b2 = dataURLToBlob(url2);
                        callback(b2 && b2.size > 0 ? b2 : null);
                    } catch (e2) {
                        callback(null);
                    }
                }
            }

            if (sigCanvas && typeof SignaturePad !== 'undefined') {
                signaturePad = new SignaturePad(sigCanvas, {
                    backgroundColor: 'rgb(255, 255, 255)',
                    penColor: 'rgb(0, 0, 0)',
                });
                function resizeSig() {
                    if (!signaturePad) return;
                    var ratio = Math.max(window.devicePixelRatio || 1, 1);
                    var w = sigCanvas.offsetWidth;
                    var h = sigCanvas.offsetHeight;
                    if (!w || !h) return;
                    sigCanvas.width = w * ratio;
                    sigCanvas.height = h * ratio;
                    sigCanvas.getContext('2d').scale(ratio, ratio);
                    signaturePad.clear();
                }
                function scheduleResize() {
                    resizeSig();
                    requestAnimationFrame(function () {
                        resizeSig();
                    });
                }
                var resizeTimer;
                window.addEventListener('resize', function () {
                    clearTimeout(resizeTimer);
                    resizeTimer = setTimeout(scheduleResize, 250);
                });
                scheduleResize();
                [0, 50, 150, 400].forEach(function (ms) {
                    setTimeout(scheduleResize, ms);
                });
                window.addEventListener('load', scheduleResize);
            }
            if (btnClearSig && signaturePad) {
                btnClearSig.addEventListener('click', function () {
                    signaturePad.clear();
                });
            }

            function stopCamera() {
                if (stream && stream.getTracks) {
                    stream.getTracks().forEach(function (t) {
                        t.stop();
                    });
                }
                stream = null;
                if (video) {
                    video.srcObject = null;
                }
            }

            async function openCamera() {
                stopCamera();
                if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                    throw new Error('Trình duyệt không hỗ trợ camera (cần HTTPS hoặc localhost).');
                }
                var attempts = [
                    { video: { facingMode: { ideal: 'environment' } }, audio: false },
                    { video: { width: { ideal: 1280 }, height: { ideal: 720 } }, audio: false },
                    { video: true, audio: false },
                ];
                var lastErr;
                for (var i = 0; i < attempts.length; i++) {
                    try {
                        stream = await navigator.mediaDevices.getUserMedia(attempts[i]);
                        video.srcObject = stream;
                        await video.play();
                        await waitVideoReady();
                        return;
                    } catch (e) {
                        lastErr = e;
                        stopCamera();
                    }
                }
                throw lastErr || new Error('Không mở được camera. Kiểm tra quyền truy cập.');
            }

            function waitVideoReady() {
                if (video.videoWidth > 0 && video.videoHeight > 0) {
                    return Promise.resolve();
                }
                return new Promise(function (resolve, reject) {
                    var to = setTimeout(function () {
                        reject(new Error('Camera chưa hiển thị hình.'));
                    }, 12000);
                    video.addEventListener(
                        'loadedmetadata',
                        function () {
                            clearTimeout(to);
                            if (video.videoWidth > 0 && video.videoHeight > 0) resolve();
                            else reject(new Error('Kích thước video = 0.'));
                        },
                        { once: true },
                    );
                });
            }
            function setInlinePhotoPreview(blob) {
                if (inlinePhotoObjectUrl) {
                    URL.revokeObjectURL(inlinePhotoObjectUrl);
                    inlinePhotoObjectUrl = null;
                }
                if (!blob || !inlinePhotoPreview || !photoPlaceholder) return;
                inlinePhotoObjectUrl = URL.createObjectURL(blob);
                inlinePhotoPreview.src = inlinePhotoObjectUrl;
                inlinePhotoPreview.classList.remove('hidden');
                photoPlaceholder.classList.add('hidden');
            }

            function clearInlinePhotoPreview() {
                if (inlinePhotoObjectUrl) {
                    URL.revokeObjectURL(inlinePhotoObjectUrl);
                    inlinePhotoObjectUrl = null;
                }
                if (inlinePhotoPreview) {
                    inlinePhotoPreview.removeAttribute('src');
                    inlinePhotoPreview.classList.add('hidden');
                }
                if (photoPlaceholder) photoPlaceholder.classList.remove('hidden');
            }

            if (btnCaptureCamera) {
                btnCaptureCamera.addEventListener('click', async function () {
                    try {
                        if (!video.srcObject) {
                            alert('Camera chưa được mở!');
                            return;
                        }
                        await waitVideoReady();
                        var vw = video.videoWidth;
                        var vh = video.videoHeight;
                        if (!vw || !vh) {
                            await new Promise(function (r) {
                                setTimeout(r, 200);
                            });
                            vw = video.videoWidth;
                            vh = video.videoHeight;
                        }
                        if (!vw || !vh) {
                            alert('Chưa lấy được khung hình từ camera. Thử lại sau vài giây.');
                            return;
                        }
                        capCanvas.width = vw;
                        capCanvas.height = vh;
                        capCanvas.getContext('2d').drawImage(video, 0, 0, vw, vh);
                        preview.src = capCanvas.toDataURL('image/jpeg', 0.92);
                        if (cameraBox) cameraBox.classList.add('hidden');
                        if (previewBox) previewBox.classList.remove('hidden');
                    } catch (err) {
                        alert(err.message || 'Lỗi chụp ảnh');
                    }
                });
            }
            if (btnRetake) {
                btnRetake.addEventListener('click', async function () {
                    if (previewBox) previewBox.classList.add('hidden');
                    if (cameraBox) cameraBox.classList.remove('hidden');
                    preview.removeAttribute('src');
                    photoBlob = null;
                    clearInlinePhotoPreview();
                    if (photoStatus) photoStatus.classList.add('hidden');
                    try {
                        if (stream && stream.getTracks().some(function (t) {
                            return t.readyState === 'live';
                        })) {
                            video.srcObject = stream;
                            await video.play();
                        } else {
                            await openCamera();
                        }
                    } catch (e) {
                        alert(e.message || 'Không mở lại được camera');
                    }
                });
            }

            var btnCloseModalFooter = document.querySelector('#btn_close_modal');
            if (btnCloseModalFooter) {
                btnCloseModalFooter.addEventListener('click', function () {
                    closeModal();
                });
            }
            if (btnModalCloseX) {
                btnModalCloseX.addEventListener('click', function () {
                    closeModal();
                });
            }

            function openModalCam() {
                if (!modal) return;
                document.body.classList.add('overflow-hidden');
                modal.classList.remove('hidden');
                if (cameraBox) cameraBox.classList.remove('hidden');
                if (previewBox) previewBox.classList.add('hidden');
                if (preview) preview.removeAttribute('src');
                openCamera()
                    .then(function () {
                        setTimeout(function () {
                            if (modalBox) {
                                modalBox.classList.remove('scale-95', 'opacity-0');
                                modalBox.classList.add('scale-100', 'opacity-100');
                            }
                        }, 10);
                    })
                    .catch(function (e) {
                        alert(e.message || 'Không mở được camera');
                        closeModal();
                    });
            }

            function closeModal() {
                if (!modal) return;
                document.body.classList.remove('overflow-hidden');
                if (modalBox) modalBox.classList.add('scale-95', 'opacity-0');
                stopCamera();
                setTimeout(function () {
                    modal.classList.add('hidden');
                }, 200);
            }
            if (btnOpenCamera && modal) {
                btnOpenCamera.addEventListener('click', openModalCam);
            }
            if (btnCaptureConfirm && modal) {
                btnCaptureConfirm.addEventListener('click', function () {
                    if (!capCanvas.width || !capCanvas.height || !preview.src) {
                        alert('Nhấn "Chụp" để lấy ảnh trước khi xác nhận.');
                        return;
                    }
                    capCanvas.toBlob(function (blob) {
                        if (!blob) {
                            alert('Không tạo được file ảnh.');
                            return;
                        }
                        photoBlob = blob;
                        setInlinePhotoPreview(blob);
                        if (photoStatus) {
                            photoStatus.classList.remove('hidden');
                        }
                        closeModal();
                    }, 'image/jpeg', 0.92);
                });
            }

            function showErr(msg) {
                if (!errEl) return;
                errEl.textContent = msg || '';
                errEl.classList.toggle('hidden', !msg);
            }

            function appendGroupCheckinMeta(fd) {
                var ga = document.getElementById('checkin_via_group_id');
                if (ga && ga.value) {
                    fd.append('checkin_via_group_id', ga.value);
                }
            }

            function postCheckinForm(fd) {
                if (!btnSubmit) return;
                appendGroupCheckinMeta(fd);
                btnSubmit.disabled = true;
                fetch('/tool-checkin/check-in', {
                    method: 'POST',
                    body: fd,
                    credentials: 'same-origin',
                })
                    .then(function (r) {
                        return r.text().then(function (text) {
                            var j = {};
                            try {
                                j = text ? JSON.parse(text) : {};
                            } catch (e) {
                                j = { mess: text || 'Lỗi ' + r.status, _raw: true };
                            }
                            return { ok: r.ok, body: j };
                        });
                    })
                    .then(function (res) {
                        if (res.ok && res.body && res.body.success) {
                            if (checkinToolCloseAndRefreshOpener()) {
                                return;
                            }
                            var retEl = document.getElementById('return_to');
                            if (retEl && retEl.value) {
                                window.location.href = retEl.value;
                                return;
                            }
                            window.location.reload();
                        } else {
                            showErr((res.body && res.body.mess) || 'Lỗi server');
                        }
                    })
                    .catch(function () {
                        showErr('Lỗi mạng hoặc server.');
                    })
                    .finally(function () {
                        btnSubmit.disabled = false;
                    });
            }

            if (btnSubmit) {
                btnSubmit.addEventListener('click', function () {
                    showErr('');
                    capMode = (document.getElementById('capture_mode') || {}).value || 'both';
                    var code = document.querySelector('#code_hidden').value.trim();
                    if (!code) {
                        showErr('Thiếu mã VĐV.');
                        return;
                    }
                    if (capMode === 'none') {
                        var fdNone = new FormData();
                        fdNone.append('code', code);
                        postCheckinForm(fdNone);
                        return;
                    }
                    if ((capMode === 'signature' || capMode === 'both') && signaturePad) {
                        if (signaturePad.isEmpty()) {
                            showErr('Vui lòng ký tên.');
                            return;
                        }
                    } else if ((capMode === 'signature' || capMode === 'both') && !signaturePad) {
                        showErr('Thiếu vùng chữ ký.');
                        return;
                    }
                    if ((capMode === 'photo' || capMode === 'both') && !photoBlob) {
                        showErr('Vui lòng chụp ảnh người tham gia.');
                        return;
                    }
                    if (capMode === 'signature') {
                        getSignatureBlob(function (sigBlob) {
                            if (!sigBlob) {
                                showErr('Không xuất được chữ ký. Thử ký lại hoặc tải lại trang.');
                                return;
                            }
                            var fd = new FormData();
                            fd.append('code', code);
                            fd.append('signature', sigBlob, 'signature.png');
                            postCheckinForm(fd);
                        });
                        return;
                    }
                    if (capMode === 'photo') {
                        var fdP = new FormData();
                        fdP.append('code', code);
                        fdP.append('photo', photoBlob, 'photo.jpg');
                        postCheckinForm(fdP);
                        return;
                    }
                    getSignatureBlob(function (sigBlob) {
                        if (!sigBlob) {
                            showErr('Không xuất được chữ ký. Thử ký lại.');
                            return;
                        }
                        var fdB = new FormData();
                        fdB.append('code', code);
                        fdB.append('signature', sigBlob, 'signature.png');
                        fdB.append('photo', photoBlob, 'photo.jpg');
                        postCheckinForm(fdB);
                    });
                });
            }
        });
    </script>
</body>
</html>
