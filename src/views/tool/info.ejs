            </div>
            <!-- Content -->
            <div class="py-6 flex flex-col items-center justify-center gap-10">
                <!-- <p class="text-gray-600 mb-6">
        </p> -->
                <!-- <button class="border border-gray-300 rounded-lg px-4 py-3" id="openCamera">Mở camera</button> -->
                <div id="cameraBox" class="w-full">
                    <video id="video" autoplay playsinline muted class="w-full max-h-64 rounded-lg border border-gray-300 bg-black object-cover"></video>
                </div>
                <div id="previewBox" class="w-full hidden">
                    <img id="preview" class="w-full max-h-64 rounded-lg border border-gray-300 object-cover" alt="Xem trước" />
                    <!-- <br /> -->
                    <!-- <button id="retake">Chụp lại</button> -->
                    <!-- <button id="upload">Upload</button> -->
                </div>

