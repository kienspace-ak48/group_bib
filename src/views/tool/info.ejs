                </div>

                <div class="space-y-1 mb-4">
                    <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">
                        Ngày Sinh / DOB
                    </p>
                    <% let dformat = new Date(pc.dob).toLocaleDateString('vi-VN') %>
