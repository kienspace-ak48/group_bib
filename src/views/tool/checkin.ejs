<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Quản lý Check-in | Hội thao Sư phạm</title>
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts: Inter + Outfit cho hiện đại -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&family=Outfit:wght@500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css" />
    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <!-- QR Scanner lib -->
    <script src="https://unpkg.com/html5-qrcode"></script>
    <!-- jQuery & DataTables JS -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
</head>
<body class="checkin-page">
<div class="dashboard-container">
    <!-- Event Header -->
    <div class="checkin-event-header">
        <div class="flex items-start justify-between gap-2 sm:gap-4">
            <h1 class="checkin-event-title">
                <span id="eventName" class=""><%= event && event.name ? event.name : 'Sự kiện' %></span>
            </h1>
            <a href="/auth/normal/admin/logout" class="checkin-logout-btn" title="Đăng xuất" aria-label="Đăng xuất">
                <i class="fas fa-right-from-bracket text-sm sm:text-base" aria-hidden="true"></i>
            </a>
        </div>
    </div>

    <!-- Action bar + search -->
    <div class="action-toolbar">
        <div class="search-area">
            <div class="search-input-group">
                <i class="fas fa-search"></i>
                <input type="text" id="custom-global-search" placeholder="Tìm theo tên, mã số, email, SĐT..." autocomplete="off">
            </div>
        </div>
        <div class="action-toolbar-right">
            <button id="openScan" type="button" class="scan-btn js-open-scan" aria-label="Mở quét mã QR">
                <i class="fas fa-qrcode" aria-hidden="true"></i> Scan QR
            </button>
        </div>
    </div>

    <div class="mobile-scan-fab" role="presentation">
        <button type="button" class="scan-btn js-open-scan" aria-label="Mở quét mã QR">
            <i class="fas fa-qrcode" aria-hidden="true"></i> Scan QR
        </button>
    </div>

    <!-- Filter chips (nâng cao UX) -->
    <div class="filter-chips">
        <div class="chip active" data-filter="all"><i class="fas fa-list-ul" aria-hidden="true"></i> Tất cả</div>
        <div class="chip" data-filter="true"><i class="fas fa-check-circle text-green-600" aria-hidden="true"></i> Đã check-in</div>
        <div class="chip" data-filter="false"><i class="fas fa-hourglass-half" aria-hidden="true"></i> Chưa check-in</div>
    </div>

    <!-- Table wrapper -->
    <div class="data-table-wrapper">
        <table id="participant_tbl" class="display w-full table-fixed text-left" style="width:100%">
            <colgroup>
                <col class="checkin-col-athlete" />
                <col class="checkin-col-contact" />
                <col class="checkin-col-status" />
            </colgroup>
            <thead>
                <tr>
                    <th>Vận động viên</th>
                    <th>Liên hệ</th>
                    <th class="whitespace-nowrap !text-center">Trạng thái</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- SCANNER MODAL - Giao diện mới -->
<div id="scanModal" class="hidden">
    <div class="scanner-container">
        <div class="scanner-header">
            <span><i class="fas fa-qrcode"></i> Quét mã check-in</span>
            <i class="fas fa-close cursor-pointer text-xl" id="closeScanIcon" role="button" tabindex="0" aria-label="Đóng"></i>
        </div>
        <div class="qr-reader-area">
            <div id="qr-reader"></div>
            <div class="scan-guide"></div>
        </div>
        <button id="closeScanBtn" class="close-scanner"><i class="fas fa-times-circle"></i> Đóng</button>
    </div>
</div>

<!-- Form ẩn submit -->
<form action="/tool-checkin/info" method="GET" class="hidden" id="checkinForm" target="checkinWindow">
    <input type="text" name="code" id="code_hidden" />
    <input type="hidden" name="return_to" value="/tool-checkin" />
</form>

<script>
    // DataTable instance
    let dataTable = null;
    let currentFilter = "all";   // 'all', 'true', 'false'
    let customSearchTerm = "";

    // ---- Fake server-side / API adapter (giữ logic giống yêu cầu nhưng dùng demo endpoint)
    // Thực tế bạn đã có ajax: '/tool-checkin/get-data' , giữ nguyên nhưng thêm filter & search thân thiện
    // Để demo UI/UX chuẩn chỉnh, ta vẫn dùng serverSide true nhưng sẽ customize gửi thêm param
    // Vì endpoint có sẵn, mình chỉ việc thêm param mỗi lần draw lại table.
    
    function initDataTable() {
        if (dataTable) {
            dataTable.destroy();
        }
        dataTable = $('#participant_tbl').DataTable({
            processing: true,
            serverSide: true,
            autoWidth: false,
            columnDefs: [
                { width: '35%', targets: 0 },
                { width: '40%', targets: 1 },
                { width: '25%', targets: 2, className: "text-center" }
            ],
            ajax: {
                url: '/tool-checkin/get-data',
                type: 'GET',
                data: function (d) {
                    d.filter_status = currentFilter;
                    d.search_custom = customSearchTerm;
                    return d;
                },
                beforeSend: function() {
                    // optional loading
                }
            },
            info: false,
            dom: 'rtp',
            searching: false,
            ordering: false,
            pageLength: 10,
            lengthChange: false,
            language: {
                info: "Hiển thị _START_ - _END_ trong tổng số _TOTAL_ vận động viên",
                paginate: {
                    previous: "<i class='fas fa-chevron-left'></i>",
                    next: "<i class='fas fa-chevron-right'></i>"
                }
            },
            columns: [
                {
                    data: null,
                    render: function (data, type, row) {
                        const bibDisplay = row.bib != null && String(row.bib).trim() !== ''
                            ? String(row.bib).trim()
                            : (row.code || row.uid || '');
                        const bibHtml = bibDisplay
                            ? `<span class="athlete-bib" title="BIB">#${escapeHtml(bibDisplay)}</span>`
                            : '';
                        return `<div class="athlete-name">
                            <span class="clickable-name" data-uid="${row.uid || row.code || ''}">${escapeHtml(row.fullname || '---')}</span>
                            ${bibHtml}
                        </div>`;
                    }
                },
                {
                    data: null,
                    render: function (data, type, row) {
                        let phone = row.phone || '';
                        let email = row.email || '';
                        const phoneLine = phone
                            ? `<span class="contact-line">${escapeHtml(phone)}</span>`
                            : '';
                        const emailLine = email
                            ? `<span class="contact-line">${escapeHtml(email)}</span>`
                            : '';
                        if (!phoneLine && !emailLine) {
                            return '<span class="contact-line text-slate-400">—</span>';
                        }
                        return `<div class="contact-row">${phoneLine}${emailLine}</div>`;
                    }
                },
                {
                    data: 'status',
                    render: function (data, type, row) {
                        let isChecked = (data === 'checked_in' || row.checkin_status === true || row.checkin_status === 'true');
                        var compact = typeof window !== 'undefined' && window.innerWidth <= 640;
                        let statusText = compact
                            ? (isChecked ? 'Đã CI' : 'Chưa')
                            : (isChecked ? 'Đã check-in' : 'Chưa check-in');
                        let badgeClass = isChecked ? "status-checkin" : "status-pending";
                        let icon = isChecked
                            ? '<i class="fas fa-check-circle" aria-hidden="true"></i>'
                            : '<i class="fas fa-hourglass-half" aria-hidden="true"></i>';
                        return `<div class="status-badge ${badgeClass}">${icon}</div>`;
                    }
                }
            ],
            createdRow: function (row, data, dataIndex) {
                let uidVal = data.uid || data.code || '';
                $(row).attr('data-uid', uidVal);
            },
            drawCallback: function () {
                $('#participant_tbl').css('width', '100%');
            },
        });
        
        // Reset về trang 1 khi đổi filter — nếu không, start cũ có thể > tổng số sau lọc → bảng trống
        function refreshTable() {
            dataTable.ajax.reload(null, true);
        }
        
        // Custom search input handler
        // $('#customSearchInput').on('keyup', function() {
        //     customSearchTerm = $(this).val();
        //     refreshTable();
        // });
        
        // Filter chips — dùng attr('data-filter') vì jQuery .data() có thể ép "true"/"false" thành boolean
        $('.chip').on('click', function() {
            $('.chip').removeClass('active');
            $(this).addClass('active');
            const filterVal = String($(this).attr('data-filter') || 'all').trim();
            if (filterVal === 'true') currentFilter = 'true';
            else if (filterVal === 'false') currentFilter = 'false';
            else currentFilter = 'all';
            refreshTable();
        });
    }
    
    // Helper escape HTML
    function escapeHtml(str) {
        if(!str) return '';
        return str.replace(/[&<>]/g, function(m) {
            if(m === '&') return '&amp;';
            if(m === '<') return '&lt;';
            if(m === '>') return '&gt;';
            return m;
        }).replace(/[\uD800-\uDBFF][\uDC00-\uDFFF]/g, function(c) {
            return c;
        });
    }
    
    // Submit form check-in (mở tab mới)
    let checkinWindow = null;
    function submitForm(code) {
        if(!code) return;
        document.querySelector('#code_hidden').value = code;
        if (!checkinWindow || checkinWindow.closed) {
            checkinWindow = window.open('', 'checkinWindow');
        }
        document.querySelector('#checkinForm').submit();
    }
    
    // ---- QR SCANNER hiện đại ----
    let html5QrCode = null;
    let isScanning = false;
    const scanModal = document.getElementById('scanModal');
    const closeScanBtns = [document.getElementById('closeScanBtn'), document.getElementById('closeScanIcon')];
    document.querySelectorAll('.js-open-scan').forEach(function (btn) {
        btn.addEventListener('click', startScan);
    });
    
    async function startScan() {
        if (isScanning) return;
        scanModal.classList.remove('hidden');
        // Đảm bảo clear cũ nếu có
        if (html5QrCode && typeof html5QrCode.clear === 'function') {
            try { await html5QrCode.clear(); } catch(e) {}
        }
        const readerDiv = document.getElementById('qr-reader');
        readerDiv.innerHTML = ''; // reset
        html5QrCode = new Html5Qrcode('qr-reader');
        
        try {
            const devices = await Html5Qrcode.getCameras();
            if (!devices.length) throw new Error('Không tìm thấy camera');
            // ưu tiên camera sau (thường là camera sau điện thoại)
            const cameraId = devices.length > 1 ? devices[1].id : devices[0].id;
            var vw = Math.min(window.innerWidth || 360, window.innerHeight || 640);
            var boxSize = Math.max(180, Math.min(280, Math.floor(vw * 0.72)));
            await html5QrCode.start(cameraId, {
                fps: 12,
                qrbox: { width: boxSize, height: boxSize },
                aspectRatio: 1.0
            }, (decodedText) => {
                // Khi quét thành công
                if (decodedText) {
                    stopScan();
                    submitForm(decodedText);
                }
            });
            isScanning = true;
        } catch(err) {
            console.error(err);
            alert('Không thể khởi động camera. Vui lòng kiểm tra quyền truy cập.');
            stopScan();
        }
    }
    
    async function stopScan() {
        if (html5QrCode && isScanning) {
            try {
                await html5QrCode.stop();
                await html5QrCode.clear();
            } catch(e) {}
        }
        scanModal.classList.add('hidden');
        isScanning = false;
    }
    
    closeScanBtns.forEach(btn => btn && btn.addEventListener('click', stopScan));
    // click ra ngoài backdrop (chỉ modal background) - dùng overlay click
    scanModal.addEventListener('click', function(e) {
        if (e.target === scanModal) stopScan();
    });
    
    // Xử lý click vào tên để xem chi tiết (submit form)
    $('#participant_tbl').on('click', '.clickable-name', function(e) {
        e.stopPropagation();
        let uid = $(this).data('uid');
        if (uid) {
            submitForm(uid);
        } else {
            // fallback lấy từ row
            let row = $(this).closest('tr');
            let uidAttr = row.attr('data-uid');
            if(uidAttr) submitForm(uidAttr);
        }
    });
    
    // Khởi tạo DataTable
    initDataTable();

    
    // Xử lý phím tắt ESC để đóng scanner
    document.addEventListener('keydown', function(e) {
        if(e.key === 'Escape' && !scanModal.classList.contains('hidden')) {
            stopScan();
        }
    });
    //
    // Kết nối ô search custom với DataTable (có debounce để tránh gọi ajax liên tục)
let searchTimer;
$('#custom-global-search').on('keyup input', function() {
    clearTimeout(searchTimer);
    const searchValue = this.value.trim();
    searchTimer = setTimeout(function() {
        customSearchTerm = searchValue;
        if (dataTable) {
            dataTable.ajax.reload(null, true);
        }
    }, 400);
});
</script>
</body>
</html>